{
  "name": "sunrise",
  "version": "0.5.0",
  "description": "A production-ready Next.js starter template designed for rapid application development with AI assistance.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --cache-strategy content --cache-location .next/cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-strategy content --cache-location .next/cache/eslint/",
    "lint:staged": "lint-staged",
    "type-check": "tsc --noEmit",
    "format": "prettier --write --cache --cache-strategy content --cache-location .next/cache/.prettiercache .",
    "format:check": "prettier --check --cache --cache-strategy content --cache-location .next/cache/.prettiercache .",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:ui:coverage": "vitest --ui --coverage",
    "email:dev": "email dev",
    "email:export": "email export",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:embeddings": "tsx scripts/seed-embeddings.ts",
    "embeddings:reset": "tsx scripts/embeddings-reset.ts",
    "db:migrate:single-doc": "tsx --env-file=.env.local scripts/migrate-knowledge-to-single-doc.ts",
    "db:reset": "prisma migrate reset --force",
    "db:drift-check": "tsx --env-file=.env.local scripts/db/check-drift.ts",
    "smoke:chat": "tsx --env-file=.env.local scripts/smoke/chat.ts",
    "smoke:orchestration": "tsx --env-file=.env.local scripts/smoke/orchestration.ts",
    "smoke:hybrid-search": "tsx --env-file=.env.local scripts/smoke/knowledge-hybrid-search.ts",
    "smoke:transcribe": "tsx --env-file=.env.local scripts/smoke/transcribe.ts",
    "smoke:vision": "tsx --env-file=.env.local scripts/smoke/vision.ts",
    "smoke:erasure": "tsx --env-file=.env.local scripts/smoke/erasure.ts",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/human-centric-engineering/sunrise.git"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "react",
    "starter",
    "template",
    "boilerplate",
    "prisma",
    "tailwind",
    "better-auth"
  ],
  "author": "Human-Centric Engineering",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/human-centric-engineering/sunrise/issues"
  },
  "homepage": "https://github.com/human-centric-engineering/sunrise#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",

    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@sentry/nextjs": "^10.62.0",
    "@tailwindcss/typography": "^0.5.20",
    "@vercel/blob": "^2.5.0",
    "@xyflow/react": "^12.11.1",
    "better-auth": "^1.6.22",

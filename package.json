{
  "name": "sunrise",
  "version": "1.0.0",
  "description": "A production-ready Next.js starter template designed for rapid application development with AI assistance.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .next/cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location .next/cache/eslint/",
    "lint:staged": "lint-staged",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "email:dev": "email dev",
    "email:export": "email export",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:embeddings": "tsx scripts/seed-embeddings.ts",
    "db:migrate:single-doc": "tsx --env-file=.env.local scripts/migrate-knowledge-to-single-doc.ts",
    "db:reset": "prisma migrate reset --force",
    "smoke:chat": "tsx --env-file=.env.local scripts/smoke/chat.ts",
    "smoke:orchestration": "tsx --env-file=.env.local scripts/smoke/orchestration.ts",
    "smoke:hybrid-search": "tsx --env-file=.env.local scripts/smoke/knowledge-hybrid-search.ts",
    "smoke:transcribe": "tsx --env-file=.env.local scripts/smoke/transcribe.ts",
    "smoke:vision": "tsx --env-file=.env.local scripts/smoke/vision.ts",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/human-centric-engineering/sunrise.git"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "react",
    "starter",
    "template",
    "boilerplate",
    "prisma",
    "tailwind",
    "better-auth"
  ],
  "author": "Human-Centric Engineering",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/human-centric-engineering/sunrise/issues"
  },
  "homepage": "https://github.com/human-centric-engineering/sunrise#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-s3": "^3.987.0",
    "@aws-sdk/s3-request-presigner": "^3.987.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.7",
    "@sentry/nextjs": "^10.38.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/blob": "^2.2.0",
    "@xyflow/react": "^12.10.2",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "dompurify": "^3.4.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "epub2": "^3.0.2",
    "gpt-tokenizer": "^3.4.0",
    "jmespath": "^0.16.0",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.563.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "^16.2.3",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-email": "^5.2.8",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "umap-js": "^1.4.0"
  },
  "overrides": {
    "hono": "^4.11.7",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.6",
    "@react-email/preview-server": "^5.2.10",
    "@react-email/render": "^2.0.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/jmespath": "^0.15.2",
    "@types/node": "^25.2.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.12",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}

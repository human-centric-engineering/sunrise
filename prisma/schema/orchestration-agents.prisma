// ============================================================================
// Agent Orchestration Layer
// ============================================================================

// Configurable AI agent persona
model AiAgent {
  id                        String   @id @default(cuid())
  name                      String
  slug                      String   @unique
  description               String   @db.Text
  systemInstructions        String   @db.Text
  systemInstructionsHistory Json     @default("[]") // [{instructions, changedAt, changedBy}]
  model                     String // e.g. "claude-sonnet-4-6", "llama3:latest". Empty string => resolve dynamically via lib/orchestration/llm/agent-resolver.ts (used by system-seeded agents on fresh installs).
  provider                  String   @default("anthropic") // e.g. "anthropic", "openai". Empty string => same dynamic-resolution contract as `model`.
  fallbackProviders         String[] @default([])
  providerConfig            Json?
  temperature               Float    @default(0.7)
  maxTokens                 Int      @default(4096)
  // How much reasoning the model should do before producing visible output.
  // Maps to ReasoningEffort in lib/orchestration/llm/types.ts:
  //   'minimal' | 'low' | 'medium' | 'high'
  // Null = use the provider's default (no `reasoning_effort` / `thinking`
  // is sent on the wire). Honoured only by reasoning-capable models;
  // dropped silently by other models. See lib/orchestration/llm/
  // model-heuristics.ts → supportsReasoningEffort().
  reasoningEffort           String?
  monthlyBudgetUsd          Float?
  // Per-turn hard cost cap (USD) for chat. Caps total LLM + tool spend for a
  // single assistant turn — defends against a reflect/orchestrator/tool loop
  // that doesn't converge. Null = inherit AiOrchestrationSettings
  // .defaultMaxCostPerTurnUsd; null there = no per-turn cap (monthly budget
  // still applies). Enforcement is in-process inside the streaming chat
  // handler; on breach the in-flight LLM stream is aborted and any pending
  // tool dispatches in the same batch are cancelled. See
  // lib/orchestration/chat/streaming-handler.ts and lib/orchestration/llm/
  // cost-caps.ts.
  maxCostPerTurnUsd         Float?
  metadata                  Json?
  knowledgeAccessMode       String   @default("full") // "full" = unrestricted KB access (default — preserves prior behaviour). "restricted" = effective doc set is (granted docs) ∪ (docs in any granted tag) ∪ (docs with scope = 'system').
  // When the chat handler forces a search_knowledge_base call (toolChoice) on the
  // first LLM iteration of a turn. "model" = unchanged (LLM decides); "first_turn" =
  // force on the opening user turn only; "every_turn" = force every user turn;
  // "keywords" = force when the user message matches any knowledgeTriggerKeywords entry.
  // No-op if the agent doesn't have search_knowledge_base enabled. See
  // lib/orchestration/chat/streaming-handler.ts.
  knowledgeRetrievalMode    String   @default("model") // model|first_turn|every_turn|keywords
  knowledgeTriggerKeywords  String[] @default([]) // trigger terms for knowledgeRetrievalMode = "keywords"
  topicBoundaries           String[] @default([]) // forbidden topic keywords/phrases for output guard
  // Inheritable system-prompt sections — see lib/orchestration/agents/resolve-effective-prompt.ts
  // Null/empty agent text => inherit from the linked AiAgentProfile (if any).
  // When populated, the `<field>Mode` column decides whether the agent text
  // replaces or is appended after the profile value.
  // Advisory honesty flag for agents dispatched for their provider/model
  // binding only, whose system prompt is assembled in application code per
  // call (the capability pattern — see BaseCapability) rather than read from
  // the stored persona / systemInstructions / guardrails / brandVoiceInstructions
  // fields. App-populated and behaviour-neutral — the runtime never reads it;
  // it only drives the admin Instructions-tab callout and re-labels the
  // "Effective prompt preview" so an operator isn't misled into tuning
  // instruction fields the live model never receives. Default false = stored
  // instructions are load-bearing (the streamChat / workflow agent_call path).
  // See components/admin/orchestration/agent-form.tsx and GitHub issue #304.
  runtimePromptManaged      Boolean  @default(false)
  runtimePromptNote         String?  @db.Text // optional operator note shown in the callout (e.g. where the real prompt is built)
  persona                   String?  @db.Text // who the agent is (identity/role); inheritable from AiAgentProfile
  brandVoiceInstructions    String?  @db.Text // tone/style; inheritable from AiAgentProfile
  guardrails                String?  @db.Text // refusals/don'ts; inheritable from AiAgentProfile
  personaMode               String   @default("override") // "override" | "append"
  voiceMode                 String   @default("override") // "override" | "append"
  guardrailsMode            String   @default("override") // "override" | "append"
  profileId                 String? // optional link to AiAgentProfile
  rateLimitRpm              Int? // per-agent rate limit (requests per minute); null = use global default
  inputGuardMode            String? // "log_only" | "warn_and_continue" | "block"; null = use global default
  outputGuardMode           String? // "log_only" | "warn_and_continue" | "block"; null = use global default
  citationGuardMode         String? // "log_only" | "warn_and_continue" | "block"; null = use global default. Flags responses that fail to cite retrieved sources or that cite hallucinated markers.
  maxHistoryTokens          Int? // override token-aware history truncation; null = use model context window
  maxHistoryMessages        Int? // override the per-agent message-count cap for conversation history; null = use platform default (MAX_HISTORY_MESSAGES). 0 = stateless (no prior messages re-sent each turn).
  retentionDays             Int? // auto-delete conversations older than N days; null = keep forever
  visibility                String   @default("internal") // "internal" | "public" | "invite_only"
  widgetConfig              Json? // per-agent embed-widget appearance + copy; see widgetConfigSchema in lib/validations/orchestration.ts. null = use DEFAULT_WIDGET_CONFIG.
  enableVoiceInput          Boolean  @default(false) // when true, surfaces a microphone control on chat surfaces (admin + embed) and accepts speech-to-text uploads. Effective state also depends on AiOrchestrationSettings.voiceInputGloballyEnabled.
  enableImageInput          Boolean  @default(false) // when true, surfaces an attach-image control on chat surfaces (admin + embed) and accepts image attachments. Effective state also depends on AiOrchestrationSettings.imageInputGloballyEnabled and the resolved chat model carrying the `vision` capability.
  enableDocumentInput       Boolean  @default(false) // when true, surfaces an attach-PDF control on chat surfaces (admin + embed) and accepts PDF attachments. Effective state also depends on AiOrchestrationSettings.documentInputGloballyEnabled and the resolved chat model carrying the `documents` capability.
  isActive                  Boolean  @default(true)
  isSystem                  Boolean  @default(false)
  // Discriminator for "what role does this agent play". Chat agents serve
  // end users via streamChat / the embed widget. Judge agents are driven
  // by the evaluation worker (and the manual-session scorer) and never
  // appear in the chat-agents list or the embed picker. Mutually
  // exclusive at the DB layer so list filters can rely on it.
  // Values: 'chat' (default) | 'judge'. New roles added by future phases
  // (e.g. 'subject' for workflow-only) become new enum values here.
  kind                      String   @default("chat")
  createdBy                 String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  // Soft-delete marker. Set by DELETE /api/v1/admin/orchestration/agents/:id
  // (along with isActive=false and a `-deleted-{id}` slug tombstone that
  // releases the unique slug for reuse). All read paths that surface agents
  // to UI / API consumers must filter `deletedAt: null`. Hard deletion stays
  // off the table because conversations, cost logs, evaluations etc. point
  // here via `onDelete: SetNull` / `Cascade` and we want the audit trail.
  deletedAt                 DateTime?
  // Most recent activity timestamp — bumped whenever a conversation is
  // created/updated for this agent or a cost log is written against it.
  // Drives the default sort on the admin agents list (after the bespoke-
  // first split). Null = never used. See lib/orchestration/agents/
  // touch-last-active.ts for the bump helper.
  lastActiveAt              DateTime?

  // Relations
  creator          User?                      @relation("AiAgentCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  profile          AiAgentProfile?            @relation(fields: [profileId], references: [id], onDelete: SetNull)
  capabilities     AiAgentCapability[]
  conversations    AiConversation[]
  userMemories     AiUserMemory[]
  evaluations      AiEvaluationSession[]
  evaluationRuns   AiEvaluationRun[]          @relation("AiEvaluationRunAgent")
  costLogs         AiCostLog[]
  inviteTokens     AiAgentInviteToken[]
  versions         AiAgentVersion[]
  embedTokens      AiAgentEmbedToken[]
  experiments      AiExperiment[]
  grantedDocuments AiAgentKnowledgeDocument[]
  grantedTags      AiAgentKnowledgeTag[]
  mcpApiKeys       McpApiKey[]

  @@index([createdBy])
  @@index([provider])
  @@index([isActive, visibility])
  @@index([profileId])
  @@index([deletedAt])
  @@index([lastActiveAt])
  @@map("ai_agent")
}

// Library of reusable persona/voice/guardrails settings that agents can
// inherit. Agents pick at most one profile; per-field mode columns on
// AiAgent (personaMode, voiceMode, guardrailsMode) decide whether the
// agent's own value (when set) overrides or appends to the profile value.
// Composition order in the rendered system prompt is:
//   [Persona] -> systemInstructions -> [Guardrails] -> [Brand Voice].
// See lib/orchestration/agents/resolve-effective-prompt.ts for the rules.
model AiAgentProfile {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text

  persona                String? @db.Text
  brandVoiceInstructions String? @db.Text
  guardrails             String? @db.Text

  isSystem  Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User?     @relation("AiAgentProfileCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  agents  AiAgent[]

  @@index([createdBy])
  @@map("ai_agent_profile")
}

// Invite token for invite_only agent access
model AiAgentInviteToken {
  id        String    @id @default(cuid())
  agentId   String
  token     String    @unique @default(cuid()) // opaque token shared with invitees
  label     String? // admin-friendly label (e.g. "Beta testers", "Partner X")
  maxUses   Int? // null = unlimited
  useCount  Int       @default(0)
  expiresAt DateTime? // null = never expires
  revokedAt DateTime? // non-null = revoked
  createdBy String?
  createdAt DateTime  @default(now())

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User?   @relation("InviteTokenCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@map("ai_agent_invite_token")
}

// Version snapshot of agent configuration for audit and rollback
model AiAgentVersion {
  id            String   @id @default(cuid())
  agentId       String
  version       Int // monotonically increasing per agent
  snapshot      Json // full agent config at this point in time
  changeSummary String?  @db.Text // auto-generated description of what changed
  createdBy     String?
  createdAt     DateTime @default(now())

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User?   @relation("AgentVersionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([agentId, version])
  @@map("ai_agent_version")
}

// Embeddable widget token for an agent — allows unauthenticated chat via embed
model AiAgentEmbedToken {
  id             String   @id @default(cuid())
  agentId        String
  token          String   @unique @default(cuid()) // opaque token for X-Embed-Token header
  label          String? // admin label (e.g. "Marketing site", "Help center")
  allowedOrigins String[] @default([]) // CORS origins; empty = allow all
  isActive       Boolean  @default(true)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User?   @relation("EmbedTokenCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@map("ai_agent_embed_token")
}

// A discrete tool/function an agent can call
model AiCapability {
  id                 String  @id @default(cuid())
  name               String
  slug               String  @unique
  description        String  @db.Text
  category           String
  functionDefinition Json // OpenAI-compatible function schema
  executionType      String // "internal", "api", "webhook"
  executionHandler   String // class path or endpoint
  executionConfig    Json?
  requiresApproval   Boolean @default(false)
  approvalTimeoutMs  Int? // ms before auto-deny/allow; null = use global default
  rateLimit          Int? // calls per minute
  // True when the capability is naturally safe to re-run — destination handles
  // duplicates, e.g. a pure read or an upsert keyed on stable input. The engine's
  // tool_call executor skips the dispatch cache for idempotent capabilities,
  // avoiding an unnecessary write per call. Default false: assume side effects
  // until the author opts in. See `lib/orchestration/engine/dispatch-cache.ts`.
  isIdempotent       Boolean @default(false)
  isActive           Boolean @default(true)
  isSystem           Boolean @default(false)
  // Emergency-disable / quarantine state. Distinct from isActive: isActive
  // toggles capability availability for routine reasons (deprecation,
  // beta gating). quarantineState is reserved for incident response —
  // "a vendor API is misbehaving, stop calling this tool now". The
  // dispatcher returns a distinct capability_quarantined error code so
  // agents can route around soft-quarantined tools, and the audit log
  // captures the action under a distinct capability.quarantine action
  // string so post-incident review can find the response window.
  // See `.context/orchestration/capabilities.md` (Quarantine section).
  quarantineState    String    @default("active") // "active" | "quarantined-soft" | "quarantined-hard"
  quarantineReason   String?
  quarantineUntil    DateTime? // null = indefinite; past timestamp = auto-cleared at read time
  metadata           Json?

  // Relations
  agents         AiAgentCapability[]
  mcpExposedTool McpExposedTool?

  @@index([category])
  @@index([executionType])
  @@index([isActive])
  @@index([quarantineState])
  @@map("ai_capability")
}

// Pivot table linking agents to capabilities
model AiAgentCapability {
  id              String  @id @default(cuid())
  agentId         String
  capabilityId    String
  isEnabled       Boolean @default(true)
  customConfig    Json?
  customRateLimit Int?

  // Relations
  agent      AiAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capability AiCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityId])
  @@index([agentId])
  @@index([capabilityId])
  @@map("ai_agent_capability")
}

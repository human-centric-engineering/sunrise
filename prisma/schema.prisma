// Prisma schema file
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// Better Auth User model
//
// ID Generation: @default(cuid()) generates 25-character CUIDs (format: c[a-z0-9]{24})
// better-auth is configured to delegate ID generation to Prisma (see lib/auth/config.ts)
// This ensures consistent CUID format across all user creation methods (UI, API, OAuth, seed)
//
// ⚠️ ERASURE POLICY — any NEW relation that points at User (a `userId` or
// `createdBy` FK) MUST declare an explicit `onDelete`:
//   • personal data            → onDelete: Cascade   (erased with the user)
//   • org config / audit / logs → onDelete: SetNull  (retained, de-attributed; make the FK nullable)
// Omitting it defaults to Restrict, which silently breaks GDPR erasure
// (prisma.user.delete throws P2003 for any user with activity). After adding
// one, extend scripts/smoke/erasure.ts to prove it. See .context/privacy/data-erasure.md.
model User {
  id            String   @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom fields for RBAC
  role String @default("USER")

  // Extended Profile Fields (Phase 3.2)
  bio         String? @db.Text // User biography (long text)
  phone       String? @db.VarChar(20) // Phone number
  timezone    String? @default("UTC") // IANA timezone (e.g., "America/New_York")
  location    String? @db.VarChar(100) // Free-form location string
  preferences Json?   @default("{}") // Email preferences as JSON

  // Relations
  sessions Session[]
  accounts Account[]

  // Agent Orchestration relations
  aiAgents               AiAgent[]               @relation("AiAgentCreator")
  aiAgentProfiles        AiAgentProfile[]        @relation("AiAgentProfileCreator")
  aiWorkflows            AiWorkflow[]            @relation("AiWorkflowCreator")
  aiWorkflowExecutions   AiWorkflowExecution[]   @relation("AiWorkflowExecutionUser")
  aiWorkflowSchedules    AiWorkflowSchedule[]    @relation("AiWorkflowScheduleCreator")
  aiWorkflowTriggers     AiWorkflowTrigger[]     @relation("AiWorkflowTriggerCreator")
  aiConversations        AiConversation[]        @relation("AiConversationUser")
  aiUserMemories         AiUserMemory[]          @relation("AiUserMemoryUser")
  aiKnowledgeDocuments   AiKnowledgeDocument[]   @relation("AiKnowledgeDocumentUploader")
  aiEvaluationSessions   AiEvaluationSession[]   @relation("AiEvaluationSessionUser")
  aiDatasets             AiDataset[]             @relation("AiDatasetUser")
  aiEvaluationRuns       AiEvaluationRun[]       @relation("AiEvaluationRunUser")
  aiProviderConfigs      AiProviderConfig[]      @relation("AiProviderConfigCreator")
  aiWebhookSubscriptions AiWebhookSubscription[] @relation("AiWebhookUser")
  aiInviteTokens         AiAgentInviteToken[]    @relation("InviteTokenCreator")
  aiAgentVersions        AiAgentVersion[]        @relation("AgentVersionCreator")
  aiWorkflowVersions     AiWorkflowVersion[]     @relation("WorkflowVersionCreator")
  aiApiKeys              AiApiKey[]              @relation("AiApiKeyUser")
  aiEventHooks           AiEventHook[]           @relation("AiEventHookCreator")
  aiProviderModels       AiProviderModel[]       @relation("AiProviderModelCreator")
  aiAdminAuditLogs       AiAdminAuditLog[]       @relation("AiAdminAuditLogUser")
  aiEmbedTokens          AiAgentEmbedToken[]     @relation("EmbedTokenCreator")
  aiExperiments          AiExperiment[]          @relation("AiExperimentCreator")

  // MCP Server relations
  mcpApiKeys        McpApiKey[]        @relation("McpApiKeyCreator")
  mcpExposedPrompts McpExposedPrompt[] @relation("McpPromptCreator")

  @@unique([email])
  @@index([role])
  @@map("user")
}

// Better Auth Session model
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

// Better Auth Account model
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // Hashed password for email/password auth
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

// Better Auth Verification model
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  metadata   Json? // Stores invitation details (name, role, invitedBy, invitedAt)

  @@index([identifier])
  @@index([expiresAt])
  @@map("verification")
}

// Contact Form Submissions (Phase 3.5)
// Stores contact form submissions from the public website
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@index([read, createdAt])
  @@map("contact_submission")
}

// Feature Flags (Phase 4.4)
// Runtime feature toggle system for admin-controlled features
model FeatureFlag {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "ENABLE_BETA_FEATURES"
  enabled     Boolean  @default(false)
  description String?  @db.Text
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@index([name])
  @@map("feature_flag")
}

// ============================================================================
// Agent Orchestration Layer
// ============================================================================

// Configurable AI agent persona
model AiAgent {
  id                        String   @id @default(cuid())
  name                      String
  slug                      String   @unique
  description               String   @db.Text
  systemInstructions        String   @db.Text
  systemInstructionsHistory Json     @default("[]") // [{instructions, changedAt, changedBy}]
  model                     String // e.g. "claude-sonnet-4-6", "llama3:latest". Empty string => resolve dynamically via lib/orchestration/llm/agent-resolver.ts (used by system-seeded agents on fresh installs).
  provider                  String   @default("anthropic") // e.g. "anthropic", "openai". Empty string => same dynamic-resolution contract as `model`.
  fallbackProviders         String[] @default([])
  providerConfig            Json?
  temperature               Float    @default(0.7)
  maxTokens                 Int      @default(4096)
  // How much reasoning the model should do before producing visible output.
  // Maps to ReasoningEffort in lib/orchestration/llm/types.ts:
  //   'minimal' | 'low' | 'medium' | 'high'
  // Null = use the provider's default (no `reasoning_effort` / `thinking`
  // is sent on the wire). Honoured only by reasoning-capable models;
  // dropped silently by other models. See lib/orchestration/llm/
  // model-heuristics.ts → supportsReasoningEffort().
  reasoningEffort           String?
  monthlyBudgetUsd          Float?
  // Per-turn hard cost cap (USD) for chat. Caps total LLM + tool spend for a
  // single assistant turn — defends against a reflect/orchestrator/tool loop
  // that doesn't converge. Null = inherit AiOrchestrationSettings
  // .defaultMaxCostPerTurnUsd; null there = no per-turn cap (monthly budget
  // still applies). Enforcement is in-process inside the streaming chat
  // handler; on breach the in-flight LLM stream is aborted and any pending
  // tool dispatches in the same batch are cancelled. See
  // lib/orchestration/chat/streaming-handler.ts and lib/orchestration/llm/
  // cost-caps.ts.
  maxCostPerTurnUsd         Float?
  metadata                  Json?
  knowledgeAccessMode       String   @default("full") // "full" = unrestricted KB access (default — preserves prior behaviour). "restricted" = effective doc set is (granted docs) ∪ (docs in any granted tag) ∪ (docs with scope = 'system').
  topicBoundaries           String[] @default([]) // forbidden topic keywords/phrases for output guard
  // Inheritable system-prompt sections — see lib/orchestration/agents/resolve-effective-prompt.ts
  // Null/empty agent text => inherit from the linked AiAgentProfile (if any).
  // When populated, the `<field>Mode` column decides whether the agent text
  // replaces or is appended after the profile value.
  persona                   String?  @db.Text // who the agent is (identity/role); inheritable from AiAgentProfile
  brandVoiceInstructions    String?  @db.Text // tone/style; inheritable from AiAgentProfile
  guardrails                String?  @db.Text // refusals/don'ts; inheritable from AiAgentProfile
  personaMode               String   @default("override") // "override" | "append"
  voiceMode                 String   @default("override") // "override" | "append"
  guardrailsMode            String   @default("override") // "override" | "append"
  profileId                 String? // optional link to AiAgentProfile
  rateLimitRpm              Int? // per-agent rate limit (requests per minute); null = use global default
  inputGuardMode            String? // "log_only" | "warn_and_continue" | "block"; null = use global default
  outputGuardMode           String? // "log_only" | "warn_and_continue" | "block"; null = use global default
  citationGuardMode         String? // "log_only" | "warn_and_continue" | "block"; null = use global default. Flags responses that fail to cite retrieved sources or that cite hallucinated markers.
  maxHistoryTokens          Int? // override token-aware history truncation; null = use model context window
  maxHistoryMessages        Int? // override the per-agent message-count cap for conversation history; null = use platform default (MAX_HISTORY_MESSAGES). 0 = stateless (no prior messages re-sent each turn).
  retentionDays             Int? // auto-delete conversations older than N days; null = keep forever
  visibility                String   @default("internal") // "internal" | "public" | "invite_only"
  widgetConfig              Json? // per-agent embed-widget appearance + copy; see widgetConfigSchema in lib/validations/orchestration.ts. null = use DEFAULT_WIDGET_CONFIG.
  enableVoiceInput          Boolean  @default(false) // when true, surfaces a microphone control on chat surfaces (admin + embed) and accepts speech-to-text uploads. Effective state also depends on AiOrchestrationSettings.voiceInputGloballyEnabled.
  enableImageInput          Boolean  @default(false) // when true, surfaces an attach-image control on chat surfaces (admin + embed) and accepts image attachments. Effective state also depends on AiOrchestrationSettings.imageInputGloballyEnabled and the resolved chat model carrying the `vision` capability.
  enableDocumentInput       Boolean  @default(false) // when true, surfaces an attach-PDF control on chat surfaces (admin + embed) and accepts PDF attachments. Effective state also depends on AiOrchestrationSettings.documentInputGloballyEnabled and the resolved chat model carrying the `documents` capability.
  isActive                  Boolean  @default(true)
  isSystem                  Boolean  @default(false)
  // Discriminator for "what role does this agent play". Chat agents serve
  // end users via streamChat / the embed widget. Judge agents are driven
  // by the evaluation worker (and the manual-session scorer) and never
  // appear in the chat-agents list or the embed picker. Mutually
  // exclusive at the DB layer so list filters can rely on it.
  // Values: 'chat' (default) | 'judge'. New roles added by future phases
  // (e.g. 'subject' for workflow-only) become new enum values here.
  kind                      String   @default("chat")
  createdBy                 String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  creator          User?                      @relation("AiAgentCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  profile          AiAgentProfile?            @relation(fields: [profileId], references: [id], onDelete: SetNull)
  capabilities     AiAgentCapability[]
  conversations    AiConversation[]
  userMemories     AiUserMemory[]
  evaluations      AiEvaluationSession[]
  evaluationRuns   AiEvaluationRun[]          @relation("AiEvaluationRunAgent")
  costLogs         AiCostLog[]
  inviteTokens     AiAgentInviteToken[]
  versions         AiAgentVersion[]
  embedTokens      AiAgentEmbedToken[]
  experiments      AiExperiment[]
  grantedDocuments AiAgentKnowledgeDocument[]
  grantedTags      AiAgentKnowledgeTag[]
  mcpApiKeys       McpApiKey[]

  @@index([createdBy])
  @@index([provider])
  @@index([isActive, visibility])
  @@index([profileId])
  @@map("ai_agent")
}

// Library of reusable persona/voice/guardrails settings that agents can
// inherit. Agents pick at most one profile; per-field mode columns on
// AiAgent (personaMode, voiceMode, guardrailsMode) decide whether the
// agent's own value (when set) overrides or appends to the profile value.
// Composition order in the rendered system prompt is:
//   [Persona] -> systemInstructions -> [Guardrails] -> [Brand Voice].
// See lib/orchestration/agents/resolve-effective-prompt.ts for the rules.
model AiAgentProfile {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text

  persona                String? @db.Text
  brandVoiceInstructions String? @db.Text
  guardrails             String? @db.Text

  isSystem  Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User?     @relation("AiAgentProfileCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  agents  AiAgent[]

  @@index([createdBy])
  @@map("ai_agent_profile")
}

// Invite token for invite_only agent access
model AiAgentInviteToken {
  id        String    @id @default(cuid())
  agentId   String
  token     String    @unique @default(cuid()) // opaque token shared with invitees
  label     String? // admin-friendly label (e.g. "Beta testers", "Partner X")
  maxUses   Int? // null = unlimited
  useCount  Int       @default(0)
  expiresAt DateTime? // null = never expires
  revokedAt DateTime? // non-null = revoked
  createdBy String?
  createdAt DateTime  @default(now())

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User?   @relation("InviteTokenCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@map("ai_agent_invite_token")
}

// Version snapshot of agent configuration for audit and rollback
model AiAgentVersion {
  id            String   @id @default(cuid())
  agentId       String
  version       Int // monotonically increasing per agent
  snapshot      Json // full agent config at this point in time
  changeSummary String?  @db.Text // auto-generated description of what changed
  createdBy     String?
  createdAt     DateTime @default(now())

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User?   @relation("AgentVersionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([agentId, version])
  @@map("ai_agent_version")
}

// Embeddable widget token for an agent — allows unauthenticated chat via embed
model AiAgentEmbedToken {
  id             String   @id @default(cuid())
  agentId        String
  token          String   @unique @default(cuid()) // opaque token for X-Embed-Token header
  label          String? // admin label (e.g. "Marketing site", "Help center")
  allowedOrigins String[] @default([]) // CORS origins; empty = allow all
  isActive       Boolean  @default(true)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User?   @relation("EmbedTokenCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@map("ai_agent_embed_token")
}

// A discrete tool/function an agent can call
model AiCapability {
  id                 String  @id @default(cuid())
  name               String
  slug               String  @unique
  description        String  @db.Text
  category           String
  functionDefinition Json // OpenAI-compatible function schema
  executionType      String // "internal", "api", "webhook"
  executionHandler   String // class path or endpoint
  executionConfig    Json?
  requiresApproval   Boolean @default(false)
  approvalTimeoutMs  Int? // ms before auto-deny/allow; null = use global default
  rateLimit          Int? // calls per minute
  // True when the capability is naturally safe to re-run — destination handles
  // duplicates, e.g. a pure read or an upsert keyed on stable input. The engine's
  // tool_call executor skips the dispatch cache for idempotent capabilities,
  // avoiding an unnecessary write per call. Default false: assume side effects
  // until the author opts in. See `lib/orchestration/engine/dispatch-cache.ts`.
  isIdempotent       Boolean @default(false)
  isActive           Boolean @default(true)
  isSystem           Boolean @default(false)
  metadata           Json?

  // Relations
  agents         AiAgentCapability[]
  mcpExposedTool McpExposedTool?

  @@index([category])
  @@index([executionType])
  @@index([isActive])
  @@map("ai_capability")
}

// Pivot table linking agents to capabilities
model AiAgentCapability {
  id              String  @id @default(cuid())
  agentId         String
  capabilityId    String
  isEnabled       Boolean @default(true)
  customConfig    Json?
  customRateLimit Int?

  // Relations
  agent      AiAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capability AiCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityId])
  @@index([agentId])
  @@index([capabilityId])
  @@map("ai_agent_capability")
}

// Reusable workflow definitions.
//
// Versioning model: each workflow has a chain of immutable `AiWorkflowVersion`
// rows (the published history) plus an optional in-progress `draftDefinition`.
// Executions resolve their definition via `publishedVersionId` so a mid-edit
// draft never alters in-flight runs. See `.context/orchestration/workflow-versioning.md`.
model AiWorkflow {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  description            String   @db.Text
  draftDefinition        Json? // in-progress edit; null when there is no draft
  publishedVersionId     String? // FK to the version executions pin to
  // Per-execution hard cost cap (USD). Default for executions of this
  // workflow when the caller does not pass an explicit budgetLimitUsd.
  // Resolution order at execution-creation time: caller override >
  // AiWorkflow.maxCostPerExecutionUsd > AiOrchestrationSettings
  // .defaultMaxCostPerExecutionUsd > unlimited. The resolved value is
  // persisted onto AiWorkflowExecution.budgetLimitUsd so resumes and
  // lease-reaper paths inherit it without re-resolving. See
  // lib/orchestration/llm/cost-caps.ts.
  maxCostPerExecutionUsd Float?
  patternsUsed           Int[] // pattern numbers used in this workflow
  isActive               Boolean  @default(true)
  isTemplate             Boolean  @default(false)
  isSystem               Boolean  @default(false)
  templateSource         String? // null = regular workflow, "builtin" = seed template, "custom" = admin-created
  metadata               Json?
  createdBy              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  creator          User?                 @relation("AiWorkflowCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  publishedVersion AiWorkflowVersion?    @relation("WorkflowPublishedVersion", fields: [publishedVersionId], references: [id])
  versions         AiWorkflowVersion[]   @relation("WorkflowVersions")
  executions       AiWorkflowExecution[]
  schedules        AiWorkflowSchedule[]
  triggers         AiWorkflowTrigger[]
  evaluationRuns   AiEvaluationRun[]     @relation("AiEvaluationRunWorkflow")

  @@index([createdBy])
  @@index([isActive])
  @@index([isTemplate])
  @@index([isSystem])
  @@index([slug, isActive]) // Webhook trigger lookups: findFirst({ slug, isActive: true })
  @@index([publishedVersionId])
  @@map("ai_workflow")
}

// Immutable snapshot of a workflow definition at publish time.
// Mirrors the AiAgentVersion model. New rows are inserted by `publishDraft` and
// `rollback`; existing rows are never mutated. Per-execution pinning is via
// `AiWorkflowExecution.versionId`.
model AiWorkflowVersion {
  id            String   @id @default(cuid())
  workflowId    String
  version       Int // monotonic per workflow, starts at 1
  snapshot      Json // full WorkflowDefinition at publish time
  changeSummary String?  @db.Text // optional admin-supplied label
  createdBy     String?
  createdAt     DateTime @default(now())

  workflow     AiWorkflow            @relation("WorkflowVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  creator      User?                 @relation("WorkflowVersionCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  publishedFor AiWorkflow[]          @relation("WorkflowPublishedVersion")
  executions   AiWorkflowExecution[]

  @@unique([workflowId, version])
  @@index([workflowId])
  @@map("ai_workflow_version")
}

// Cron-based workflow scheduling
model AiWorkflowSchedule {
  id             String    @id @default(cuid())
  workflowId     String
  name           String
  cronExpression String    @db.VarChar(100)
  inputTemplate  Json      @default("{}")
  isEnabled      Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  workflow AiWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  creator  User?      @relation("AiWorkflowScheduleCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([workflowId])
  @@index([isEnabled, nextRunAt])
  @@map("ai_workflow_schedule")
}

// Inbound trigger from a third-party system (Slack, Postmark, generic-HMAC). Each row
// binds (channel, workflow) so the inbound route can dispatch incoming requests to the
// right workflow. Channel-wide secrets (Slack signing secret, Postmark basic-auth) live
// in env vars; per-trigger generic-HMAC secrets are stored as plaintext on `signingSecret`,
// mirroring `AiEventHook.secret` (HMAC needs the original secret on both sides; the at-rest
// security model treats the DB as admin-trusted). `metadata` carries channel-specific config
// (event-type filter, allowed senders, ...).
model AiWorkflowTrigger {
  id            String    @id @default(cuid())
  workflowId    String
  channel       String    @db.VarChar(40) // "slack" | "postmark" | "hmac"
  name          String
  metadata      Json      @default("{}")
  signingSecret String?   @db.Text // per-trigger HMAC shared secret (plaintext, mirrors AiEventHook.secret); null for env-var-keyed channels
  isEnabled     Boolean   @default(true)
  lastFiredAt   DateTime?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workflow AiWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  creator  User?      @relation("AiWorkflowTriggerCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([channel, workflowId]) // one trigger per (channel, workflow); v2 may relax for multi-event setups
  @@index([workflowId])
  @@index([channel, isEnabled])
  @@map("ai_workflow_trigger")
}

// Runtime workflow instances
model AiWorkflowExecution {
  id                   String    @id @default(cuid())
  workflowId           String
  versionId            String? // pinned AiWorkflowVersion at trigger time; null on legacy rows only
  status               String // "pending", "running", "paused_for_approval", "completed", "failed", "cancelled"
  inputData            Json
  outputData           Json?
  // Resume cursor: the most-recently-entered step's id. Engine writes on
  // every `markCurrentStep`; preserved across finalize for post-mortem
  // diagnostics. The full set of in-flight steps lives on the side table
  // `AiWorkflowRunningStep` (one row per running branch) so a `parallel`
  // fan-out is fully observable; this scalar is just the cursor used by
  // the resume path and as a short pointer for the in-flight banner.
  currentStep          String?
  executionTrace       Json // array of step execution logs
  totalTokensUsed      Int       @default(0)
  totalCostUsd         Float     @default(0)
  budgetLimitUsd       Float?
  startedAt            DateTime?
  completedAt          DateTime?
  errorMessage         String?   @db.Text
  // Trigger attribution. Source is `schedule | webhook | chat | inbound:<channel>` (free-form;
  // not enforced as enum so new sources can be added without migration). External ID carries
  // vendor-supplied identifiers (Slack `event_id`, Postmark `MessageID`); used for human/audit
  // attribution only. Dedup is keyed on `dedupKey` so shared-secret channels (Slack, Postmark)
  // can dedup globally across workflows even though the same external ID is allowed to appear
  // for unrelated per-trigger HMAC events.
  triggerSource        String?   @db.VarChar(50)
  triggerExternalId    String?
  dedupKey             String?
  // Recovery state for crash-survival. `leaseToken` identifies the host currently driving
  // the run; the orphan sweep claims rows whose `leaseExpiresAt` has elapsed and re-drives
  // them through the resume path. `lastHeartbeatAt` is observability-only. `recoveryAttempts`
  // caps re-drives — after the cap the row is failed permanently. See
  // `lib/orchestration/engine/orchestration-engine.ts` (claim/refresh/clear) and
  // `lib/orchestration/engine/execution-reaper.ts` (sweep).
  leaseToken           String?
  leaseExpiresAt       DateTime?
  lastHeartbeatAt      DateTime?
  recoveryAttempts     Int       @default(0)
  // Supervisor verdict columns. Populated by any executor that emits
  // `StepResult.contextPatch` — the supervisor step is the first user.
  // Persisted on the row for fast querying ("which runs failed the
  // neutral audit?") without parsing the trace JSON.
  // Values: 'pass' | 'concerns' | 'fail' | 'inconclusive'. NULL means
  // no supervisor has run on this execution.
  supervisorVerdict    String?
  supervisorScore      Float?
  supervisorReport     Json?
  supervisorReviewedAt DateTime?
  // Lineage: when this execution was triggered via the rerun endpoint
  // (`POST /executions/:id/rerun`) this points at the execution it was
  // rerun from. The admin UI surfaces this as a "Re-run of execution X"
  // breadcrumb. NULL for normal executions and for the parent of a
  // rerun chain. `onDelete: SetNull` so deleting the parent doesn't
  // cascade away children's history — the lineage link goes muted but
  // the child stays.
  parentExecutionId    String?
  userId               String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  workflow       AiWorkflow                      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version        AiWorkflowVersion?              @relation(fields: [versionId], references: [id], onDelete: SetNull)
  user           User?                           @relation("AiWorkflowExecutionUser", fields: [userId], references: [id], onDelete: Cascade)
  parent         AiWorkflowExecution?            @relation("ExecutionLineage", fields: [parentExecutionId], references: [id], onDelete: SetNull)
  reruns         AiWorkflowExecution[]           @relation("ExecutionLineage")
  costLogs       AiCostLog[]
  stepDispatches AiWorkflowStepDispatch[]
  runningSteps   AiWorkflowRunningStep[]
  leaseEvents    AiWorkflowExecutionLeaseEvent[]

  // Inbound-trigger dedup keyed on `dedupKey`. Route computes per-channel scope:
  //   - shared-secret channels (slack, postmark): `<channel>:<externalId>` — globally per channel
  //   - per-trigger HMAC: `hmac:<workflowId>:<externalId>` — scoped per trigger
  // Postgres treats NULLs as distinct, so non-inbound rows (NULL dedupKey) never collide.
  @@unique([dedupKey], map: "ai_workflow_execution_dedup_key")
  @@index([workflowId])
  @@index([versionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, startedAt]) // Zombie reaper: RUNNING rows past threshold
  @@index([status, createdAt]) // Stale-pending reaper + execution list filters
  @@index([status, updatedAt]) // Abandoned-approval reaper
  @@index([status, leaseExpiresAt]) // Orphan sweep: RUNNING rows with expired lease
  @@index([userId, status, createdAt]) // Execution list with user + status + sort
  @@index([parentExecutionId]) // "find all reruns of this execution" lookup
  @@map("ai_workflow_execution")
}

// Side-effect dispatch cache for crash-safe re-runs. Risky executors
// (`external_call`, `send_notification`, `tool_call`) compute a deterministic
// idempotency key per dispatch and call `recordDispatch` after the side effect
// completes. On re-drive after a crash, `lookupDispatch` hits this row and the
// executor returns the cached result without re-firing the side effect. The
// `idempotencyKey` UNIQUE constraint is the dedup gate — two hosts racing on
// the same key see exactly one winner.
//
// Capabilities flagged `isIdempotent: true` on `AiCapability` opt out of this
// cache (the destination handles duplicates), avoiding a DB write per call.
//
// See `lib/orchestration/engine/dispatch-cache.ts` and
// `.context/orchestration/workflows.md` (Idempotency section).
model AiWorkflowStepDispatch {
  id             String   @id @default(cuid())
  executionId    String
  stepId         String
  // Set for multi-turn step types (`agent_call`, `orchestrator`, `reflect`)
  // where each turn is independently keyed; null for single-shot steps.
  turnIndex      Int?
  idempotencyKey String   @unique
  result         Json
  createdAt      DateTime @default(now())

  execution AiWorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, stepId]) // resume-time replay lookup per execution+step
  @@index([createdAt]) // future cleanup of stale cache rows
  @@map("ai_workflow_step_dispatch")
}

// In-flight step tracker. One row per step that's currently executing
// (or paused awaiting approval) for an execution. The engine inserts a
// row on every `markCurrentStep` and deletes on every step terminate
// (success / failure / skip / reject / cancel). During a `parallel`
// fan-out, each branch gets its own row — that's the whole reason this
// is a side table and not scalar columns on `AiWorkflowExecution`,
// which would last-writer-wins. The detail-page live poll reads this to
// synthesise one "running" trace entry per branch.
//
// `turns` holds the multi-turn checkpoint state for `agent_call` /
// `orchestrator` / `reflect` (the executors that record per-turn
// state). It's per-step here, not per-execution — `markCurrentStep`'s
// upsert deliberately doesn't touch this column on conflict, so the
// resume path picks up the recorded turns when the engine re-enters
// the same stepId after a crash, retry, or approval round-trip.
//
// See `lib/orchestration/engine/orchestration-engine.ts`
// (markCurrentStep / recordStepTurn / clearRunningStep / startOrResume).
model AiWorkflowRunningStep {
  id          String    @id @default(cuid())
  executionId String
  stepId      String
  label       String
  stepType    String
  startedAt   DateTime  @default(now())
  // Set when this step finishes but the surrounding batch (e.g. a
  // parallel fan-out) is still in flight. Lets the live poll surface
  // "done but waiting for siblings" so the timeline can render a
  // greyed wait segment after the coloured processing portion. Null
  // for sequential steps and for parallel branches that are still
  // running. Rows are deleted (not just nulled) once the whole batch
  // settles in the post-`Promise.allSettled` loop.
  completedAt DateTime?
  turns       Json?

  execution AiWorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, stepId])
  @@index([executionId])
  @@map("ai_workflow_running_step")
}

// Append-only history of lease transitions for an execution. The lease
// inspector (admin live-engine surface) reads this to answer "is the
// engine restarting? has this execution been claimed by multiple hosts?"
// The execution row itself only holds the *current* lease state, so
// without this table there is no way to see prior claim/recover events.
//
// Written from `lib/orchestration/engine/lease.ts` on every successful
// claim, heartbeat-loss bail-out, release, and orphan-resume; and from
// the admin force-fail route when an admin terminates a run early.
// Pruned by the maintenance tick after the configured retention window.
//
// `leaseToken` stores ONLY the last 5 chars of the token (prefixed `…`)
// — the full token is a write-capability secret and must never appear
// in audit data. Operators correlate by the tail; that's enough.
model AiWorkflowExecutionLeaseEvent {
  id          String   @id @default(cuid())
  executionId String
  event       String // "claimed" | "refresh-failed" | "released" | "orphan-resume" | "force-failed"
  leaseToken  String? // redacted tail (e.g. "…ab12c"); nullable for events with no token in play
  reason      String? // e.g. "fresh-resume", "admin-force-fail", "engine-terminal"
  metadata    Json?
  createdAt   DateTime @default(now())

  execution AiWorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@index([createdAt]) // retention prune
  @@map("ai_workflow_execution_lease_event")
}

// Chat sessions
model AiConversation {
  id                   String    @id @default(cuid())
  userId               String?
  agentId              String
  title                String?
  contextType          String?
  contextId            String?
  metadata             Json?
  summary              String?   @db.Text
  summaryUpToMessageId String?
  tags                 String[]  @default([])
  isActive             Boolean   @default(true)
  // Channel/provider split — see plan decision 3.
  // `channel` is the semantic medium (sms / whatsapp / email / slack / chat).
  // `provider` is the vendor slug (twilio / meta / vonage / ...). The
  // @@unique([agentId, channel, fromAddress]) below deliberately excludes
  // provider so memory continuity survives a provider swap mid-deployment,
  // and the DB-side UNIQUE serialises concurrent inbound webhooks to a
  // single conversation row (without it, a find-or-create race could
  // duplicate rows and let the STOP/opt-out flag land on the wrong one,
  // bypassing TCPA/PECR compliance on subsequent outbound).
  channel              String?
  provider             String?
  fromAddress          String?
  lastInboundAt        DateTime?
  smsOptedOut          Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  user             User?                @relation("AiConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  agent            AiAgent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages         AiMessage[]
  costLogs         AiCostLog[]
  share            AiConversationShare?
  outboundMessages AiOutboundMessage[]

  @@unique([agentId, channel, fromAddress], name: "ai_conversation_inbound_key")
  @@index([userId])
  @@index([agentId])
  @@index([contextType, contextId])
  @@index([isActive])
  @@index([updatedAt])
  @@map("ai_conversation")
}

// Outbound message ledger for SMS / WhatsApp / future channels.
//
// Purpose: idempotency + per-recipient throttling for outbound messages
// dispatched via the `send_message_to_channel` capability. Each row records
// a dispatch attempt with a deterministic `dedupKey` so workflow retries
// don't send the same SMS twice; a UNIQUE collision returns the cached
// `transactionId` instead of re-dispatching.
//
// The (conversationId, createdAt) index powers the per-recipient hour
// window throttle check inside the capability. See plan decision 5.
model AiOutboundMessage {
  id             String   @id @default(cuid())
  conversationId String
  dedupKey       String   @unique
  channel        String // 'sms' | 'whatsapp' | future
  provider       String // 'twilio' | 'meta' | future
  transactionId  String?
  status         String // 'pending' | 'sent' | 'failed'
  errorCode      String?
  errorMessage   String?  @db.Text
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_outbound_message")
}

// Consent record for cross-user conversation access.
//
// End users own their conversations. An admin (or any other user) can view
// another user's conversation only when the owner has explicitly created
// an active share. The unique constraint on `conversationId` means a
// conversation has at most one share row at a time — re-sharing after a
// revoke updates the existing row (clear `revokedAt`, refresh `expiresAt`,
// optionally update `reason`).
//
// "Active" means `revokedAt IS NULL AND (expiresAt IS NULL OR expiresAt > now())`.
// Callers should use the `adminCanViewConversation` helper rather than
// hand-rolling that predicate. The default time limit is 7 days, enforced
// at the route layer (the schema allows null for never-expiring shares
// which a future compliance-officer role may use).
//
// See `.context/security/conversation-access.md` for the consent posture.
model AiConversationShare {
  id             String    @id @default(cuid())
  conversationId String    @unique
  reason         String?   @db.Text
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("ai_conversation_share")
}

// Individual messages
//
// Provenance columns mirror the supervisor-on-execution pattern (5 scalars +
// 1 JSON bundle on `AiWorkflowExecution`). Scalars are indexed for query
// ("show me every message produced by agent vN", "...routed to model X");
// the `provenance` JSON column holds the structured evidence bundle —
// citations (with documentVersion + contentHash), workflow step sources
// snapshotted at message-creation time, and capability calls.
//
// `workflowExecutionId` is NOT a foreign key — executions can be pruned
// independently of messages. The column is a snapshot reference, same
// treatment as `modelId` (a string snapshot, not an FK to `AiModel`).
model AiMessage {
  id             String    @id @default(cuid())
  conversationId String
  role           String // "user", "assistant", "system", "tool"
  content        String    @db.Text
  metadata       Json? // {tokenUsage, latencyMs, costUsd, sideEffectModels, pendingApproval, error}
  capabilitySlug String?
  toolCallId     String?
  rating         Int? // -1 = thumbs down, 1 = thumbs up, null = unrated
  ratedAt        DateTime?
  createdAt      DateTime  @default(now())

  // Provenance — version pins captured at message-creation time
  agentVersionId      String?
  workflowExecutionId String?
  workflowVersionId   String?
  modelId             String?
  providerSlug        String?

  // Provenance bundle — typed as MessageProvenance in types/orchestration.ts
  // Shape: { citations: Citation[], workflowSources?: ProvenanceItem[], capabilityCalls?: ToolCallTrace[] }
  provenance Json?

  // Relations
  conversation     AiConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  evaluationLogs   AiEvaluationLog[]
  messageEmbedding AiMessageEmbedding?

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([role])
  @@index([createdAt])
  @@index([rating])
  @@index([agentVersionId])
  @@index([workflowExecutionId])
  @@index([modelId])
  @@map("ai_message")
}

// Embedding vector for semantic search over conversation messages.
//
// The `embedding` column dimension is rebuilt by `npm run embeddings:reset`
// whenever the active embedding model in `AiOrchestrationSettings` changes,
// since pgvector locks dimension at the column level. Today's active model
// is `text-embedding-3-small` (1536-dim).
// ⚠️ PRISMA-SCHEMA DRIFT WARNING ⚠️
// The Postgres HNSW index `idx_message_embedding` on the `embedding`
// column is managed via raw SQL — Prisma cannot model HNSW indexes on
// `Unsupported("vector(N)")` columns natively, so it doesn't appear here.
//
// `npx prisma migrate dev` WILL try to add a `DROP INDEX
// "idx_message_embedding"` line on every schema-diff run. Always inspect
// generated migration SQL and remove that line before applying — the
// drop would silently break similarity search.
//
// Source of truth:
//   prisma/migrations/20260420063847_add_message_embedding_hnsw_index/
//   prisma/migrations/20260514151915_flexible_embedding_models_and_kb_grouping/ (re-creates)
model AiMessageEmbedding {
  id                 String                      @id @default(cuid())
  messageId          String                      @unique
  embedding          Unsupported("vector(1536)")
  embeddingModel     String?
  embeddingProvider  String?
  embeddingDimension Int?

  message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("ai_message_embedding")
}

// Configurable event hooks for orchestration events
// Fires on events like conversation.started, message.created,
// workflow.completed, etc. Webhook-only action type.
model AiEventHook {
  id        String   @id @default(cuid())
  name      String
  eventType String   @db.VarChar(100) // e.g. "conversation.started", "workflow.completed"
  action    Json // { type: 'webhook', url, headers }
  filter    Json? // optional event filtering e.g. { agentSlug: 'support-bot' }
  isEnabled Boolean  @default(true)
  secret    String?  @db.Text // HMAC-SHA256 signing key (hex); nullable = unsigned
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creator    User?                 @relation("AiEventHookCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  deliveries AiEventHookDelivery[]

  @@index([eventType])
  @@index([isEnabled])
  @@map("ai_event_hook")
}

// Delivery history / retry queue for webhook-type AiEventHook dispatches.
// Internal handlers run in-process and are not tracked here.
model AiEventHookDelivery {
  id               String    @id @default(cuid())
  hookId           String
  eventType        String
  payload          Json
  status           String    @default("pending") // pending, delivered, failed, exhausted
  attempts         Int       @default(0)
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  lastResponseCode Int?
  lastError        String?   @db.Text
  createdAt        DateTime  @default(now())

  hook AiEventHook @relation(fields: [hookId], references: [id], onDelete: Cascade)

  @@index([hookId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("ai_event_hook_delivery")
}

// Per-user-per-agent key-value memory (preferences, prior topics, facts)
model AiUserMemory {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  key       String   @db.VarChar(255)
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User    @relation("AiUserMemoryUser", fields: [userId], references: [id], onDelete: Cascade)
  agent AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId, key])
  @@index([userId, agentId])
  @@map("ai_user_memory")
}

// Logical grouping for knowledge documents — a "corpus". Reserved for future
// per-KB embedding-model selection (Layer 2); today every KB shares the
// global active embedding model from AiOrchestrationSettings.
model AiKnowledgeBase {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents AiKnowledgeDocument[]

  @@map("ai_knowledge_base")
}

// Source documents uploaded to the knowledge base
model AiKnowledgeDocument {
  id              String   @id @default(cuid())
  knowledgeBaseId String
  name            String
  fileName        String
  fileHash        String // SHA-256 for deduplication
  chunkCount      Int      @default(0)
  status          String // "processing", "ready", "failed"
  scope           String   @default("app") // "system" | "app"
  sourceUrl       String? // URL the document was fetched from (null = manual upload)
  errorMessage    String?  @db.Text
  metadata        Json? // format-specific metadata, preview data for pending_review docs
  uploadedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  knowledgeBase AiKnowledgeBase            @relation(fields: [knowledgeBaseId], references: [id])
  uploader      User?                      @relation("AiKnowledgeDocumentUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)
  chunks        AiKnowledgeChunk[]
  tags          AiKnowledgeDocumentTag[]
  agentGrants   AiAgentKnowledgeDocument[]

  @@index([uploadedBy])
  @@index([status])
  @@index([scope])
  @@index([fileHash])
  @@index([knowledgeBaseId])
  @@map("ai_knowledge_document")
}

// Vector store for knowledge base content.
//
// ⚠️ PRISMA-SCHEMA DRIFT WARNING ⚠️
// The Postgres GIN index `idx_ai_knowledge_chunk_search_vector` on
// `searchVector` (and the `GENERATED ALWAYS` DEFAULT on the same column)
// are managed via raw SQL in migrations — Prisma cannot model `tsvector`
// GIN indexes or generated columns natively, so they don't appear here.
//
// `npx prisma migrate dev` WILL try to add DROP statements for both on
// every schema-diff run. Always inspect generated migration SQL and
// remove any lines touching `idx_ai_knowledge_chunk_search_vector` or
// the `searchVector` DEFAULT before applying. The drops would silently
// break hybrid search.
//
// Source of truth: prisma/migrations/20260501172919_add_knowledge_chunk_search_vector/
model AiKnowledgeChunk {
  id                 String                       @id @default(cuid())
  chunkKey           String                       @unique
  documentId         String
  content            String                       @db.Text
  embedding          Unsupported("vector(1536)")?
  // GENERATED ALWAYS AS (to_tsvector('english', content || keywords)) STORED — managed by migration, populated by Postgres.
  searchVector       Unsupported("tsvector")?
  chunkType          String // "pattern_section", "pattern_overview", "glossary", etc.
  patternNumber      Int?
  patternName        String?
  section            String?
  keywords           String?                      @db.Text
  estimatedTokens    Int?
  embeddingModel     String? // e.g. "voyage-3", "text-embedding-3-small"
  embeddingProvider  String? // e.g. "voyage", "openai-compatible", "ollama"
  embeddingDimension Int? // explicit dim of the stored vector; doesn't infer from model (matryoshka-truncated models share IDs but differ in dim)
  embeddedAt         DateTime? // when the embedding was generated
  metadata           Json?

  // Relations
  document AiKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([chunkType])
  @@index([patternNumber])
  @@map("ai_knowledge_chunk")
}

// Managed taxonomy of knowledge "tags" — replaced the legacy free-text `knowledgeCategories[]` on AiAgent (dropped in Phase 6).
// Many-to-many at both ends: tags ↔ documents (via AiKnowledgeDocumentTag) and tags ↔ agents (via AiAgentKnowledgeTag).
model KnowledgeTag {
  id          String   @id @default(cuid())
  slug        String   @unique // stable cross-environment key (used in backup/export)
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents AiKnowledgeDocumentTag[]
  agents    AiAgentKnowledgeTag[]

  @@map("knowledge_tag")
}

// Join table: which documents carry which tags
model AiKnowledgeDocumentTag {
  documentId String
  tagId      String
  createdAt  DateTime @default(now())

  document AiKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      KnowledgeTag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("ai_knowledge_document_tag")
}

// Join table: which agents may access which documents (only consulted when AiAgent.knowledgeAccessMode = 'restricted')
model AiAgentKnowledgeDocument {
  agentId    String
  documentId String
  createdAt  DateTime @default(now())

  agent    AiAgent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  document AiKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([agentId, documentId])
  @@index([documentId])
  @@map("ai_agent_knowledge_document")
}

// Join table: which agents may access docs tagged with which tags
model AiAgentKnowledgeTag {
  agentId   String
  tagId     String
  createdAt DateTime @default(now())

  agent AiAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tag   KnowledgeTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([agentId, tagId])
  @@index([tagId])
  @@map("ai_agent_knowledge_tag")
}

// Testing sessions for agents
model AiEvaluationSession {
  id                     String    @id @default(cuid())
  userId                 String
  agentId                String? // nullable so SetNull can preserve history when the agent is deleted
  title                  String
  description            String?   @db.Text
  status                 String // "draft", "in_progress", "completed", "archived"
  summary                String?   @db.Text
  improvementSuggestions Json?
  // { avgFaithfulness, avgGroundedness, avgRelevance, scoredLogCount,
  //   judgeProvider, judgeModel, scoredAt, totalScoringCostUsd }
  metricSummary          Json?
  startedAt              DateTime?
  completedAt            DateTime?
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  user               User                  @relation("AiEvaluationSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  agent              AiAgent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  logs               AiEvaluationLog[]
  experimentVariants AiExperimentVariant[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@map("ai_evaluation_session")
}

// Per-turn evaluation logs
model AiEvaluationLog {
  id                String   @id @default(cuid())
  sessionId         String
  messageId         String?
  sequenceNumber    Int
  eventType         String // "user_input", "ai_response", "capability_call", "capability_result", "error"
  content           String?  @db.Text
  inputData         Json?
  outputData        Json?
  capabilitySlug    String?
  executionTimeMs   Int?
  tokenUsage        Json?
  metadata          Json?
  // Named-metric scores attached to ai_response logs by the judge LLM at
  // completion / rescore time. Null until scored. Faithfulness can stay
  // null even after scoring when the response had no inline citations.
  faithfulnessScore Float?
  groundednessScore Float?
  relevanceScore    Float?
  // { faithfulness: { reasoning }, groundedness: { reasoning },
  //   relevance: { reasoning } } — display-only.
  judgeReasoning    Json?
  createdAt         DateTime @default(now())

  // Relations
  session AiEvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message AiMessage?          @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([messageId])
  @@index([eventType])
  @@map("ai_evaluation_log")
}

// ---------------------------------------------------------------------------
// Dataset-driven evaluations (Phase 1)
// ---------------------------------------------------------------------------

/// A curated collection of test cases run against an agent (or workflow).
/// Datasets are immutable in content via `contentHash` — edits change the
/// hash, which makes them visible (but not destructive) to historical runs.
model AiDataset {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?  @db.Text
  // Free-text tags for filtering. Mirrors the AiKnowledgeDocument tag
  // pattern; lower-case, no separate tag table.
  tags        String[] @default([])
  caseCount   Int      @default(0)
  // SHA-256 of the normalised case array (positions sorted, JSON-stringified).
  // Pinned on every AiEvaluationRun so an edit doesn't silently invalidate
  // historical run comparisons.
  contentHash String
  // Provenance: how this dataset was created — 'upload' (CSV/JSONL),
  // 'manual' (created case-by-case in UI), 'synthetic' (Phase 2 LLM gen),
  // 'conversation_capture' (Phase 2 trace-to-dataset, conversation source),
  // 'workflow_capture' (Phase 2 trace-to-dataset, workflow execution source).
  source      String   @default("upload")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User?             @relation("AiDatasetUser", fields: [userId], references: [id], onDelete: SetNull)
  cases          AiDatasetCase[]
  evaluationRuns AiEvaluationRun[]
  experiments    AiExperiment[]    @relation("AiExperimentDataset")

  @@index([userId, updatedAt])
  @@map("ai_dataset")
}

/// One test case inside an AiDataset. `input` is JSON to allow both
/// string-shaped (agent message) and object-shaped (workflow input vars)
/// cases without a schema split. `expectedOutput` is optional — required
/// only by reference-dependent graders (exact_match, contains, …).
model AiDatasetCase {
  id                 String  @id @default(cuid())
  datasetId          String
  // 0-based stable order inside the dataset; drives iteration & result joins.
  position           Int
  input              Json
  expectedOutput     String? @db.Text
  // Optional ground-truth retrieval contexts for RAG-style graders
  // (context_recall, context_precision) — added by Phase 2 work.
  referenceCitations Json?
  // Author-supplied case-level metadata: tags, difficulty, expectedTrajectory,
  // source ('synthetic' | 'conversation_capture' | 'workflow_capture'), …
  metadata           Json?

  dataset AiDataset                @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  results AiEvaluationCaseResult[]

  @@unique([datasetId, position])
  @@index([datasetId])
  @@map("ai_dataset_case")
}

/// A queued/running/completed evaluation run: pairs a dataset with a
/// subject (agent OR workflow), records grader configs and judge model,
/// owns the per-case results and aggregated summary. Drained by the
/// maintenance-tick worker via lease/orphan-claim semantics.
///
/// Invariant: exactly one of `agentId` / `workflowId` is non-null. Enforced
/// at the application layer (Zod) and by the worker dispatch branch — no
/// DB CHECK constraint to keep migrations portable across Postgres
/// versions / hosted offerings that restrict DDL.
model AiEvaluationRun {
  id                    String    @id @default(cuid())
  userId                String
  name                  String
  description           String?   @db.Text
  // 'agent' | 'workflow' — drives the worker's per-case dispatch.
  subjectKind           String
  agentId               String?
  workflowId            String?
  datasetId             String
  // Dataset content hash captured at submit time. The worker validates
  // this against the dataset's current hash on claim; mismatch ⇒ fail.
  datasetContentHash    String
  // Array<{ slug: string; config: unknown }> — pinned at submit time so
  // grader-registry edits don't silently invalidate historical runs.
  // Rubric prompts for `custom_rubric` are embedded here verbatim.
  metricConfigs         Json
  // Judge model resolution: explicit override > env default > system
  // chat default. Null fields = "use the resolver".
  judgeProvider         String?
  judgeModel            String?
  // Optional: for workflow subjects, which step's output to grade.
  // { kind: 'final_report' | 'last_step' | 'step_id', stepId?: string }.
  // Phase 1 UI is agent-only; this field is wired so Phase 3 ships
  // without schema rework.
  subjectOutputSelector Json?
  status                String    @default("queued") // queued | running | completed | failed | cancelled
  // { casesTotal, casesDone, casesFailed } — updated by the worker
  // every few cases (throttled to avoid hot DB writes per iteration).
  progress              Json      @default("{\"casesTotal\":0,\"casesDone\":0,\"casesFailed\":0}")
  // Per-metric aggregates after completion:
  // { metricSlugs: string[], stats: { [slug]: { mean, median, p95, passRate, scoredCount } },
  //   judgeProvider, judgeModel, completedAt, note? }
  summary               Json?
  totalCostUsd          Float?
  // For "Rescore as new run" — copies metrics/judge but fresh result rows.
  parentRunId           String?
  // Worker lease — mirrors processOrphanedExecutions semantics. Cleared
  // on completion or after the 5-min orphan threshold.
  lockedBy              String?
  lockedAt              DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user     User                     @relation("AiEvaluationRunUser", fields: [userId], references: [id], onDelete: Cascade)
  agent    AiAgent?                 @relation("AiEvaluationRunAgent", fields: [agentId], references: [id], onDelete: SetNull)
  workflow AiWorkflow?              @relation("AiEvaluationRunWorkflow", fields: [workflowId], references: [id], onDelete: SetNull)
  dataset  AiDataset                @relation(fields: [datasetId], references: [id])
  parent   AiEvaluationRun?         @relation("AiEvaluationRunRescore", fields: [parentRunId], references: [id], onDelete: SetNull)
  rescores AiEvaluationRun[]        @relation("AiEvaluationRunRescore")
  results  AiEvaluationCaseResult[]
  variants AiExperimentVariant[]

  @@index([userId, updatedAt])
  @@index([status, lockedAt])
  @@index([datasetId])
  @@index([agentId])
  @@index([workflowId])
  @@map("ai_evaluation_run")
}

/// Result row for a single (run × case) pair. Written by the worker
/// after subject execution + grading. `metricScores` is keyed by grader
/// slug; a missing key means the grader was skipped (e.g. `exact_match`
/// without `expectedOutput`).
model AiEvaluationCaseResult {
  id              String   @id @default(cuid())
  runId           String
  datasetCaseId   String
  // Mirror of position at result-write time; lets us order results
  // without joining the dataset case row.
  casePosition    Int
  subjectOutput   String   @db.Text
  // Token usage, citations, capability calls — whatever the agent/workflow
  // emitted that graders need to inspect.
  subjectMetadata Json?
  // { [graderSlug]: { score: number | null, passed?: boolean,
  //                   reasoning?: string, costUsd?: number } }
  metricScores    Json
  latencyMs       Int
  costUsd         Float    @default(0)
  // Set when subject execution itself failed (not when a grader skipped).
  errorCode       String?
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  run         AiEvaluationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  datasetCase AiDatasetCase   @relation(fields: [datasetCaseId], references: [id])

  @@unique([runId, casePosition])
  @@index([runId])
  @@index([datasetCaseId])
  @@map("ai_evaluation_case_result")
}

// Granular cost tracking
model AiCostLog {
  id                  String   @id @default(cuid())
  agentId             String?
  conversationId      String?
  workflowExecutionId String?
  model               String
  provider            String
  inputTokens         Int
  outputTokens        Int
  inputCostUsd        Float
  outputCostUsd       Float
  totalCostUsd        Float
  isLocal             Boolean  @default(false)
  operation           String // "chat", "tool_call", "embedding", "evaluation"
  metadata            Json?
  // OTEL trace correlation — set when an active tracer span exists at the
  // logCost call site. Nullable for legacy rows and for code paths where
  // tracing is not registered (default no-op tracer returns empty IDs).
  traceId             String?
  spanId              String?
  createdAt           DateTime @default(now())

  // Relations
  agent             AiAgent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  conversation      AiConversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  workflowExecution AiWorkflowExecution? @relation(fields: [workflowExecutionId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([conversationId])
  @@index([workflowExecutionId])
  @@index([provider])
  @@index([operation])
  @@index([createdAt])
  @@index([agentId, createdAt])
  @@index([traceId])
  @@map("ai_cost_log")
}

// Webhook subscriptions for outbound event notifications
model AiWebhookSubscription {
  id             String   @id @default(cuid())
  // Delivery channel — "webhook" routes to `url` with HMAC signing;
  // "email" routes to `emailAddress` via the generic event-notification
  // template. The model is kept as `AiWebhookSubscription` for
  // backward-compat with API paths and migrations; the channel column
  // discriminates which destination fields are required.
  channel        String   @default("webhook")
  url            String? // destination URL — required when channel = "webhook"
  secret         String? // HMAC-SHA256 signing key — required when channel = "webhook"
  emailAddress   String? // destination email — required when channel = "email"
  events         String[] // e.g. ["budget_exceeded","workflow_failed"]
  // Optional entity scoping. Empty array means "no constraint on this dimension".
  // The dispatcher applies dimension-specific filtering: `agentIds` only constrains
  // events whose payload carries an agent ID, `workflowIds` only constrains events
  // whose payload carries a workflow ID. A sub with `agentIds=['x']` still receives
  // workflow-typed events unconstrained. See lib/orchestration/webhooks/event-entity-keys.ts.
  agentIds       String[] @default([])
  workflowIds    String[] @default([])
  isActive       Boolean  @default(true)
  description    String?
  // Total delivery attempts before the delivery is marked `exhausted` (1–10).
  // For email rows we still record attempts in AiWebhookDelivery for audit,
  // but Resend handles its own retry semantics so the policy is effectively
  // a soft cap on local retries triggered by us.
  maxAttempts    Int      @default(3)
  // Backoff delays in ms between successive attempts. Must contain at least
  // (maxAttempts - 1) entries; the dispatcher only reads the first
  // (maxAttempts - 1) values. Each entry capped at 24h.
  retryBackoffMs Int[]    @default([10000, 60000, 300000])
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User                @relation("AiWebhookUser", fields: [createdBy], references: [id], onDelete: Cascade)
  deliveries AiWebhookDelivery[]

  @@index([isActive])
  @@index([createdBy])
  @@index([channel])
  @@map("ai_webhook_subscription")
}

// Webhook delivery tracking — records each delivery attempt for audit + retry
model AiWebhookDelivery {
  id               String    @id @default(cuid())
  subscriptionId   String
  eventType        String
  payload          Json
  status           String    @default("pending") // pending, delivered, failed, exhausted
  attempts         Int       @default(0)
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  lastResponseCode Int?
  lastError        String?   @db.Text
  createdAt        DateTime  @default(now())

  subscription AiWebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("ai_webhook_delivery")
}

// Configured LLM providers
model AiProviderConfig {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  providerType String // "anthropic", "openai-compatible"
  baseUrl      String? // API base URL (required for openai-compatible)
  apiKeyEnvVar String? // env var name e.g. "ANTHROPIC_API_KEY"
  isLocal      Boolean  @default(false)
  isActive     Boolean  @default(true)
  metadata     Json?
  timeoutMs    Int? // per-provider request timeout; null = use default (30s cloud, 10s local)
  maxRetries   Int? // per-provider retry count; null = use default (3)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  creator User? @relation("AiProviderConfigCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([providerType])
  @@index([isActive])
  @@map("ai_provider_config")
}

// Provider model matrix — per-model landscape analysis
model AiProviderModel {
  id           String @id @default(cuid())
  slug         String @unique // "openai-gpt-5", "voyage-voyage-3"
  providerSlug String // groups models: "openai", "anthropic", "voyage"
  modelId      String // API model id: "gpt-5", "voyage-3"
  name         String // display name: "GPT-5", "Voyage 3"
  description  String @db.Text

  // Classification
  capabilities String[] @default(["chat"]) // ["chat"], ["embedding"], ["chat","embedding"]
  tierRole     String // 'thinking' | 'worker' | 'infrastructure' | 'control_plane' | 'embedding'

  // Deployment profile — orthogonal to tierRole. A model can be a `thinking`-tier
  // chat LLM that is also `sovereign`-deployable (e.g. Qwen2.5-72B) without
  // forcing a false choice in the tier classification. Defaults to ["hosted"]
  // (the most common case — vendor-hosted via API). Models that run on the
  // operator's own infrastructure carry "sovereign". Reserved values for future
  // expansion: "edge" (browser/device), "air_gapped" (no outbound network).
  deploymentProfiles String[] @default(["hosted"])

  // Wire-level parameter convention. Maps to ParamProfile in
  // lib/orchestration/llm/types.ts. Determines whether the OpenAI-compatible
  // provider sends `max_tokens` vs `max_completion_tokens` and whether
  // `temperature` is honoured. Nullable: when null, deriveParamProfile() in
  // model-heuristics.ts derives a fallback from model id + provider, so
  // rows from before this column existed keep working.
  paramProfile String? // 'openai-legacy' | 'openai-reasoning' | 'anthropic' | 'gemini'

  // Selection matrix dimensions
  reasoningDepth String // 'very_high' | 'high' | 'medium' | 'none'
  latency        String // 'very_fast' | 'fast' | 'medium'
  costEfficiency String // 'very_high' | 'high' | 'medium' | 'none'
  contextLength  String // 'very_high' | 'high' | 'medium' | 'n_a'
  toolUse        String // 'strong' | 'moderate' | 'none'
  bestRole       String // free-text, e.g. "Planner / orchestrator"

  // Embedding-specific (nullable for chat-only models)
  dimensions           Int?
  schemaCompatible     Boolean?
  costPerMillionTokens Float?
  hasFreeTier          Boolean?
  local                Boolean  @default(false)
  quality              String? // 'high' | 'medium' | 'budget'
  strengths            String?  @db.Text
  setup                String?  @db.Text

  // Lifecycle
  isDefault Boolean  @default(false) // true = seed-managed, re-seedable
  isActive  Boolean  @default(true)
  metadata  Json?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creator                    User?                     @relation("AiProviderModelCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  activeForEmbeddingSettings AiOrchestrationSettings[] @relation("ActiveEmbeddingModel")

  @@unique([providerSlug, modelId])
  @@index([createdBy])
  @@index([isActive])
  @@index([tierRole])
  @@index([providerSlug])
  @@map("ai_provider_model")
}

// Per-user API key for programmatic access (alternative to session auth)
model AiApiKey {
  id           String    @id @default(cuid())
  userId       String
  name         String // admin-friendly label (e.g. "My CI Key")
  keyHash      String    @unique // SHA-256 hash of the API key (key itself never stored)
  keyPrefix    String // first 8 chars for display (e.g. "sk_abc12...")
  scopes       String[]  @default(["chat"]) // "chat", "analytics", "knowledge", "admin"
  rateLimitRpm Int? // per-key rate limit (requests per minute); null = use global default
  lastUsedAt   DateTime?
  expiresAt    DateTime? // null = never expires
  revokedAt    DateTime? // non-null = revoked
  createdAt    DateTime  @default(now())

  user User @relation("AiApiKeyUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("ai_api_key")
}

/// Singleton settings row for agent orchestration, keyed by `slug = "global"`.
///
/// Holds admin-editable defaults that cross-cut the orchestration layer:
///   * `defaultModels` — `{ routing, chat, reasoning, embeddings }` map used by
///     `getDefaultModelForTask()` in `lib/orchestration/llm/model-registry.ts`.
///   * `globalMonthlyBudgetUsd` — optional month-to-date spend ceiling across
///     *all* agents, consulted by `checkBudget()` in `lib/orchestration/llm/cost-tracker.ts`.
///
/// Upserted lazily on the first `GET /api/v1/admin/orchestration/settings`
/// call; never touched by the seeder so admin edits survive deploys.
model AiOrchestrationSettings {
  id                            String    @id @default(cuid())
  slug                          String    @unique @default("global")
  defaultModels                 Json // { routing: string, chat: string, reasoning: string, embeddings: string }
  activeEmbeddingModelId        String? // FK → AiProviderModel; the model whose dimension the vector columns are currently sized for. Null = use resolver default.
  globalMonthlyBudgetUsd        Float?
  // Org-wide default for AiWorkflow.maxCostPerExecutionUsd. Applies when a
  // workflow has no per-workflow value AND the caller passes no explicit
  // budgetLimitUsd. Null = no default (unlimited unless caller/workflow
  // sets one). See lib/orchestration/llm/cost-caps.ts.
  defaultMaxCostPerExecutionUsd Float?
  // Org-wide default for AiAgent.maxCostPerTurnUsd. Applies when an agent
  // has no per-agent value. Null = no default (no per-turn cap; monthly
  // budget still applies). See lib/orchestration/llm/cost-caps.ts and
  // lib/orchestration/chat/streaming-handler.ts.
  defaultMaxCostPerTurnUsd      Float?
  searchConfig                  Json? // { keywordBoostWeight: number, vectorWeight: number }
  lastSeededAt                  DateTime?
  defaultApprovalTimeoutMs      Int? // ms before auto-action on approval gates; null = no timeout
  approvalDefaultAction         String?   @default("deny") // "deny" or "allow"
  inputGuardMode                String?   @default("log_only") // "log_only", "warn_and_continue", "block"
  outputGuardMode               String?   @default("log_only") // "log_only", "warn_and_continue", "block"
  citationGuardMode             String?   @default("log_only") // "log_only", "warn_and_continue", "block"
  webhookRetentionDays          Int?
  // Separate retention window for `exhausted` (DLQ) webhook deliveries.
  // Null falls back to webhookRetentionDays so behaviour matches the
  // pre-DLQ retention model.
  webhookDlqRetentionDays       Int?
  costLogRetentionDays          Int?
  auditLogRetentionDays         Int?
  // Workflow-execution history retention. Prunes terminal executions
  // (completed / failed / cancelled) older than N days; the cascade removes
  // steps, dispatches, lease events, per-step cost logs, and inbound-trigger
  // payloads (which live in AiWorkflowExecution.inputData). Null = keep
  // forever. Running / pending / awaiting-approval executions are never
  // pruned regardless of age.
  executionRetentionDays        Int?
  // Evaluation history retention (AiEvaluationSession / Run / Log). Null =
  // keep forever. Should be <= executionRetentionDays: eval runs JSON-
  // reference the executions they ran (no FK), so a shorter execution window
  // would dangle those links. See .context/orchestration/retention.md.
  evaluationRetentionDays       Int?
  maxConversationsPerUser       Int?
  maxMessagesPerConversation    Int?
  escalationConfig              Json? // { emailAddresses, webhookUrl?, notifyOnPriority }
  embedAllowedOrigins           Json      @default("[]") // [string] — allowlist for the /approvals/:id/{approve,reject}/embed CORS scope
  voiceInputGloballyEnabled     Boolean   @default(true) // org-wide kill switch for the voice-input feature; when false, every agent's enableVoiceInput flag is treated as off regardless of its own value.
  imageInputGloballyEnabled     Boolean   @default(true) // org-wide kill switch for image attachments on chat; when false, every agent's enableImageInput flag is treated as off regardless of its own value.
  documentInputGloballyEnabled  Boolean   @default(true) // org-wide kill switch for PDF / document attachments on chat; when false, every agent's enableDocumentInput flag is treated as off regardless of its own value.
  // Minutes a running execution may spend in its current step before the
  // executions list highlights the row as "stuck-looking" and the live-
  // engine dashboard counts it in the stuck-age band. Read by the live
  // page + the executions list. Clamped to [1, 1440] on PATCH; the read
  // path defends with the same clamp so a bad DB value never breaks the UI.
  stuckExecutionThresholdMins   Int       @default(5)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  activeEmbeddingModel AiProviderModel? @relation("ActiveEmbeddingModel", fields: [activeEmbeddingModelId], references: [id], onDelete: SetNull)

  @@map("ai_orchestration_settings")
}

/// Immutable audit trail for admin configuration changes.
///
/// Fire-and-forget writes — never blocks the request. Tracks agent edits,
/// workflow changes, knowledge uploads, settings changes, and deletions.
model AiAdminAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // e.g. "agent.create", "agent.update", "workflow.delete"
  entityType String // "agent", "workflow", "capability", "knowledge_document", "settings", "webhook"
  entityId   String?
  entityName String? // human-readable name at time of action
  changes    Json? // { field: { from, to } } diff for updates
  metadata   Json? // extra context
  clientIp   String?
  createdAt  DateTime @default(now())

  user User? @relation("AiAdminAuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("ai_admin_audit_log")
}

// A/B prompt experiment — compares agent version variants
model AiExperiment {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  status        String   @default("draft") // "draft" | "running" | "completed"
  agentId       String
  // Phase 2: shared dataset every variant's eval run fires against.
  // Null on legacy rows that pre-date dataset-driven experiments — those
  // still execute via the legacy AiEvaluationSession path. Required on
  // any new experiment that opts into per-variant AiEvaluationRun.
  datasetId     String?
  // Phase 2: metric configs pinned at run time. Array<{ slug, config }>
  // mirroring AiEvaluationRun.metricConfigs. Null on legacy rows; the
  // run route uses [judge_agent: eval-judge-relevance] as a sensible
  // default when both fields are null on a draft.
  metricConfigs Json?
  // Erasure: SetNull-retained (de-attributed) when the creator is erased.
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agent    AiAgent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  dataset  AiDataset?            @relation("AiExperimentDataset", fields: [datasetId], references: [id], onDelete: SetNull)
  creator  User?                 @relation("AiExperimentCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  variants AiExperimentVariant[]

  @@index([agentId])
  @@index([status])
  @@index([datasetId])
  @@map("ai_experiment")
}

// A variant (arm) in an A/B experiment — points to an agent version snapshot
model AiExperimentVariant {
  id                  String  @id @default(cuid())
  experimentId        String
  agentVersionId      String? // references AiAgentVersion.id (null if using live agent)
  // Wired in Phase 1 alongside AiEvaluationRun; the legacy
  // `evaluationSessionId` stays for the manual chat path (Phase 2 will
  // promote experiment.finalize to read from evaluationRun.summary).
  evaluationSessionId String?
  evaluationRunId     String?
  label               String // e.g. "Control", "Variant A"
  score               Float? // aggregated evaluation score after run

  experiment        AiExperiment         @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  evaluationSession AiEvaluationSession? @relation(fields: [evaluationSessionId], references: [id], onDelete: SetNull)
  evaluationRun     AiEvaluationRun?     @relation(fields: [evaluationRunId], references: [id], onDelete: SetNull)

  @@index([experimentId])
  @@index([evaluationSessionId])
  @@index([evaluationRunId])
  @@map("ai_experiment_variant")
}

/// Tracks which seed units have been applied, keyed by unit name.
///
/// Each entry in `prisma/seeds/` is hashed by source content; the runner
/// skips units whose hash matches the stored `contentHash`, and re-runs
/// units whose file has changed. This lets teammates pull new/edited
/// seeds and apply them incrementally without manual coordination.
model SeedHistory {
  id          String   @id @default(cuid())
  name        String   @unique
  contentHash String
  appliedAt   DateTime @default(now())
  durationMs  Int

  @@map("seed_history")
}

/// Append-only receipt of a completed right-to-erasure (account deletion).
///
/// Written inside the same transaction as `prisma.user.delete` by
/// `lib/privacy/erase-user.ts`, so a receipt exists iff the user was erased.
/// Demonstrates GDPR Art. 5(2) accountability without re-introducing the
/// subject's PII: the user id is opaque (the row is gone) and the email is
/// stored only as a SHA-256 hash for correlating a later "did you erase me?"
/// request. No foreign keys — the receipt must outlive every referenced row,
/// including the actor if they are later erased too.
model DataErasureReceipt {
  id               String   @id @default(cuid())
  subjectUserId    String // id of the erased user (no FK — the user row is gone)
  subjectEmailHash String? // sha256(lowercased email); for correlation, not reversible
  actorUserId      String? // who initiated the erasure (self or an admin)
  reason           String // "self_service" | "admin_action"
  erasedAt         DateTime @default(now())
  metadata         Json? // optional summary (e.g. counts)

  @@index([subjectUserId])
  @@index([erasedAt])
  @@map("data_erasure_receipt")
}

// ============================================================================
// MCP Server
// ============================================================================

/// Singleton settings row for MCP server configuration, keyed by `slug = "global"`.
///
/// Controls the master enable/disable switch and global defaults for MCP
/// server behaviour. Upserted lazily on first read, matching the
/// `AiOrchestrationSettings` pattern.
model McpServerConfig {
  id                 String   @id @default(cuid())
  slug               String   @unique @default("global")
  isEnabled          Boolean  @default(false)
  serverName         String   @default("Sunrise MCP Server")
  serverVersion      String   @default("1.0.0")
  maxSessionsPerKey  Int      @default(5)
  globalRateLimit    Int      @default(60) // requests per minute per API key
  auditRetentionDays Int      @default(90)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("mcp_server_config")
}

/// Pivot table linking an AiCapability to MCP exposure.
///
/// Each capability can be optionally exposed as an MCP tool. `isEnabled`
/// defaults to false (default-deny) — nothing is exposed until an admin
/// explicitly enables it.
///
/// The tool-annotation hint fields below (`customTitle`, `readOnlyHint`,
/// `destructiveHint`, `idempotentHint`, `openWorldHint`) implement the
/// 2025-06-18 MCP spec tool annotations. Per spec they are **advisory only**
/// — compliant clients still treat every tool as untrusted; the hints just
/// inform UX (e.g. surface a warning before invoking a destructive tool).
/// `idempotentHint` overrides `AiCapability.isIdempotent` in the MCP
/// context when set, since the same capability may behave differently when
/// invoked by an external MCP client vs. an internal agent.
model McpExposedTool {
  id                String  @id @default(cuid())
  capabilityId      String  @unique
  isEnabled         Boolean @default(false)
  customName        String? // override MCP tool name (must match ^[a-z][a-z0-9_]*$)
  customDescription String? @db.Text
  rateLimitPerKey   Int? // per-key calls/min; null = use capability default
  requiresScope     String? // optional scope string for fine-grained access

  // MCP 2025-06-18 tool annotations (advisory hints to clients)
  customTitle     String? // human-readable title; falls back to capability.name
  readOnlyHint    Boolean? // true = does not modify state
  destructiveHint Boolean? // true = MAY perform destructive updates (only relevant if readOnlyHint=false)
  idempotentHint  Boolean? // overrides capability.isIdempotent for MCP context
  openWorldHint   Boolean? // true = interacts with an open world (e.g. web search, external API)

  // Relations
  capability AiCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@index([isEnabled])
  @@map("mcp_exposed_tool")
}

/// Prompt templates exposed to MCP clients.
///
/// Per MCP spec, prompts are **user-facing slash-command templates** that
/// clients surface to end-users — not auto-invoked by the model. The
/// template is a string with `{{var}}` substitution; substitution is
/// strictly limited to the names declared in `argumentsSpec` so admins
/// cannot accidentally (or maliciously) reference server-side data.
///
/// `name` is immutable post-create because changing it breaks every
/// bookmarked / saved client invocation. Renames require delete + recreate.
model McpExposedPrompt {
  id              String  @id @default(cuid())
  name            String  @unique // /^[a-z][a-z0-9_-]*$/, max 64
  description     String  @db.Text // shown to MCP clients in prompts/list
  template        String  @db.Text // {{var}} substitution; max 10_000 chars
  argumentsSpec   Json // [{ name, description, required }] — max 20 entries
  completionsSpec Json? // optional { [argName]: string[] } for completion/complete (Phase 6)
  isEnabled       Boolean @default(true)
  createdBy       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User? @relation("McpPromptCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([isEnabled])
  @@map("mcp_exposed_prompt")
}

/// Data endpoints exposed via MCP resources.
///
/// Each resource has a `sunrise://` URI and maps to an internal handler
/// that returns data without any external fetch.
model McpExposedResource {
  id            String  @id @default(cuid())
  uri           String  @unique // e.g. "sunrise://knowledge/search"
  name          String
  description   String  @db.Text
  mimeType      String  @default("application/json")
  resourceType  String // "knowledge_search", "agent_list", "pattern_detail", "workflow_list"
  isEnabled     Boolean @default(false)
  handlerConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
  @@index([resourceType])
  @@map("mcp_exposed_resource")
}

/// Bearer tokens for MCP client authentication.
///
/// Only the SHA-256 hash of the key is stored — the plaintext is returned
/// once at creation and never again. Keys use a `smcp_` prefix for easy
/// identification.
model McpApiKey {
  id                String    @id @default(cuid())
  name              String
  keyHash           String    @unique // SHA-256 hash of the API key
  keyPrefix         String // first 8 chars for UI identification (e.g. "smcp_a1b2")
  scopes            String[] // e.g. ["tools:list", "tools:execute", "resources:read"]
  scopedAgentId     String? // when non-null, MCP calls via this key are scoped to that agent (resources see only that agent's knowledge grants). When null, the key is an explicit "unscoped service key" with system-wide access.
  isActive          Boolean   @default(true)
  expiresAt         DateTime?
  lastUsedAt        DateTime?
  rateLimitOverride Int? // per-key rate limit override; null = use global default
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  creator     User?         @relation("McpApiKeyCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  scopedAgent AiAgent?      @relation(fields: [scopedAgentId], references: [id], onDelete: SetNull)
  auditLogs   McpAuditLog[]

  @@index([keyHash])
  @@index([createdBy])
  @@index([isActive])
  @@index([scopedAgentId])
  @@map("mcp_api_key")
}

/// Immutable audit trail for MCP server operations.
///
/// Every MCP method call is logged with client IP, duration, and result.
/// Request params are sanitized and truncated before storage.
model McpAuditLog {
  id            String   @id @default(cuid())
  apiKeyId      String?
  method        String // "tools/call", "tools/list", "resources/read", "initialize", etc.
  toolSlug      String?
  resourceUri   String?
  requestParams Json? // sanitized, truncated to 10KB
  responseCode  String // "success", "error", "rate_limited"
  errorMessage  String?  @db.Text
  durationMs    Int
  clientIp      String?
  userAgent     String?
  createdAt     DateTime @default(now())

  // Relations
  apiKey McpApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([apiKeyId])
  @@index([createdAt])
  @@index([method])
  @@index([toolSlug])
  @@map("mcp_audit_log")
}

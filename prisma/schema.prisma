// Prisma schema file
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// Better Auth User model
//
// ID Generation: @default(cuid()) generates 25-character CUIDs (format: c[a-z0-9]{24})
// better-auth is configured to delegate ID generation to Prisma (see lib/auth/config.ts)
// This ensures consistent CUID format across all user creation methods (UI, API, OAuth, seed)
model User {
  id            String   @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom fields for RBAC
  role String @default("USER")

  // Extended Profile Fields (Phase 3.2)
  bio         String? @db.Text // User biography (long text)
  phone       String? @db.VarChar(20) // Phone number
  timezone    String? @default("UTC") // IANA timezone (e.g., "America/New_York")
  location    String? @db.VarChar(100) // Free-form location string
  preferences Json?   @default("{}") // Email preferences as JSON

  // Relations
  sessions Session[]
  accounts Account[]

  // Agent Orchestration relations
  aiAgents               AiAgent[]               @relation("AiAgentCreator")
  aiWorkflows            AiWorkflow[]            @relation("AiWorkflowCreator")
  aiWorkflowExecutions   AiWorkflowExecution[]   @relation("AiWorkflowExecutionUser")
  aiWorkflowSchedules    AiWorkflowSchedule[]    @relation("AiWorkflowScheduleCreator")
  aiWorkflowTriggers     AiWorkflowTrigger[]     @relation("AiWorkflowTriggerCreator")
  aiConversations        AiConversation[]        @relation("AiConversationUser")
  aiUserMemories         AiUserMemory[]          @relation("AiUserMemoryUser")
  aiKnowledgeDocuments   AiKnowledgeDocument[]   @relation("AiKnowledgeDocumentUploader")
  aiEvaluationSessions   AiEvaluationSession[]   @relation("AiEvaluationSessionUser")
  aiProviderConfigs      AiProviderConfig[]      @relation("AiProviderConfigCreator")
  aiWebhookSubscriptions AiWebhookSubscription[] @relation("AiWebhookUser")
  aiInviteTokens         AiAgentInviteToken[]    @relation("InviteTokenCreator")
  aiAgentVersions        AiAgentVersion[]        @relation("AgentVersionCreator")
  aiWorkflowVersions     AiWorkflowVersion[]     @relation("WorkflowVersionCreator")
  aiApiKeys              AiApiKey[]              @relation("AiApiKeyUser")
  aiEventHooks           AiEventHook[]           @relation("AiEventHookCreator")
  aiProviderModels       AiProviderModel[]       @relation("AiProviderModelCreator")
  aiAdminAuditLogs       AiAdminAuditLog[]       @relation("AiAdminAuditLogUser")
  aiEmbedTokens          AiAgentEmbedToken[]     @relation("EmbedTokenCreator")
  aiExperiments          AiExperiment[]          @relation("AiExperimentCreator")

  // MCP Server relations
  mcpApiKeys McpApiKey[] @relation("McpApiKeyCreator")

  @@unique([email])
  @@index([role])
  @@map("user")
}

// Better Auth Session model
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

// Better Auth Account model
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // Hashed password for email/password auth
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

// Better Auth Verification model
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  metadata   Json? // Stores invitation details (name, role, invitedBy, invitedAt)

  @@index([identifier])
  @@index([expiresAt])
  @@map("verification")
}

// Contact Form Submissions (Phase 3.5)
// Stores contact form submissions from the public website
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@index([read, createdAt])
  @@map("contact_submission")
}

// Feature Flags (Phase 4.4)
// Runtime feature toggle system for admin-controlled features
model FeatureFlag {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "ENABLE_BETA_FEATURES"
  enabled     Boolean  @default(false)
  description String?  @db.Text
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@index([name])
  @@map("feature_flag")
}

// ============================================================================
// Agent Orchestration Layer
// ============================================================================

// Configurable AI agent persona
model AiAgent {
  id                        String   @id @default(cuid())
  name                      String
  slug                      String   @unique
  description               String   @db.Text
  systemInstructions        String   @db.Text
  systemInstructionsHistory Json     @default("[]") // [{instructions, changedAt, changedBy}]
  model                     String // e.g. "claude-sonnet-4-6", "llama3:latest"
  provider                  String   @default("anthropic")
  fallbackProviders         String[] @default([])
  providerConfig            Json?
  temperature               Float    @default(0.7)
  maxTokens                 Int      @default(4096)
  monthlyBudgetUsd          Float?
  metadata                  Json?
  knowledgeCategories       String[] @default([]) // knowledge base category filter — empty = all
  topicBoundaries           String[] @default([]) // forbidden topic keywords/phrases for output guard
  brandVoiceInstructions    String?  @db.Text // brand voice prompt appended to system instructions
  rateLimitRpm              Int? // per-agent rate limit (requests per minute); null = use global default
  inputGuardMode            String? // "log_only" | "warn_and_continue" | "block"; null = use global default
  outputGuardMode           String? // "log_only" | "warn_and_continue" | "block"; null = use global default
  citationGuardMode         String? // "log_only" | "warn_and_continue" | "block"; null = use global default. Flags responses that fail to cite retrieved sources or that cite hallucinated markers.
  maxHistoryTokens          Int? // override token-aware history truncation; null = use model context window
  retentionDays             Int? // auto-delete conversations older than N days; null = keep forever
  visibility                String   @default("internal") // "internal" | "public" | "invite_only"
  widgetConfig              Json? // per-agent embed-widget appearance + copy; see widgetConfigSchema in lib/validations/orchestration.ts. null = use DEFAULT_WIDGET_CONFIG.
  isActive                  Boolean  @default(true)
  isSystem                  Boolean  @default(false)
  createdBy                 String
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  creator       User                  @relation("AiAgentCreator", fields: [createdBy], references: [id])
  capabilities  AiAgentCapability[]
  conversations AiConversation[]
  userMemories  AiUserMemory[]
  evaluations   AiEvaluationSession[]
  costLogs      AiCostLog[]
  inviteTokens  AiAgentInviteToken[]
  versions      AiAgentVersion[]
  embedTokens   AiAgentEmbedToken[]
  experiments   AiExperiment[]

  @@index([createdBy])
  @@index([provider])
  @@index([isActive, visibility])
  @@map("ai_agent")
}

// Invite token for invite_only agent access
model AiAgentInviteToken {
  id        String    @id @default(cuid())
  agentId   String
  token     String    @unique @default(cuid()) // opaque token shared with invitees
  label     String? // admin-friendly label (e.g. "Beta testers", "Partner X")
  maxUses   Int? // null = unlimited
  useCount  Int       @default(0)
  expiresAt DateTime? // null = never expires
  revokedAt DateTime? // non-null = revoked
  createdBy String
  createdAt DateTime  @default(now())

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User    @relation("InviteTokenCreator", fields: [createdBy], references: [id])

  @@index([agentId])
  @@map("ai_agent_invite_token")
}

// Version snapshot of agent configuration for audit and rollback
model AiAgentVersion {
  id            String   @id @default(cuid())
  agentId       String
  version       Int // monotonically increasing per agent
  snapshot      Json // full agent config at this point in time
  changeSummary String?  @db.Text // auto-generated description of what changed
  createdBy     String
  createdAt     DateTime @default(now())

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User    @relation("AgentVersionCreator", fields: [createdBy], references: [id])

  @@unique([agentId, version])
  @@map("ai_agent_version")
}

// Embeddable widget token for an agent — allows unauthenticated chat via embed
model AiAgentEmbedToken {
  id             String   @id @default(cuid())
  agentId        String
  token          String   @unique @default(cuid()) // opaque token for X-Embed-Token header
  label          String? // admin label (e.g. "Marketing site", "Help center")
  allowedOrigins String[] @default([]) // CORS origins; empty = allow all
  isActive       Boolean  @default(true)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User    @relation("EmbedTokenCreator", fields: [createdBy], references: [id])

  @@index([agentId])
  @@map("ai_agent_embed_token")
}

// A discrete tool/function an agent can call
model AiCapability {
  id                 String  @id @default(cuid())
  name               String
  slug               String  @unique
  description        String  @db.Text
  category           String
  functionDefinition Json // OpenAI-compatible function schema
  executionType      String // "internal", "api", "webhook"
  executionHandler   String // class path or endpoint
  executionConfig    Json?
  requiresApproval   Boolean @default(false)
  approvalTimeoutMs  Int? // ms before auto-deny/allow; null = use global default
  rateLimit          Int? // calls per minute
  isActive           Boolean @default(true)
  isSystem           Boolean @default(false)
  metadata           Json?

  // Relations
  agents         AiAgentCapability[]
  mcpExposedTool McpExposedTool?

  @@index([category])
  @@index([executionType])
  @@index([isActive])
  @@map("ai_capability")
}

// Pivot table linking agents to capabilities
model AiAgentCapability {
  id              String  @id @default(cuid())
  agentId         String
  capabilityId    String
  isEnabled       Boolean @default(true)
  customConfig    Json?
  customRateLimit Int?

  // Relations
  agent      AiAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capability AiCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityId])
  @@index([agentId])
  @@index([capabilityId])
  @@map("ai_agent_capability")
}

// Reusable workflow definitions.
//
// Versioning model: each workflow has a chain of immutable `AiWorkflowVersion`
// rows (the published history) plus an optional in-progress `draftDefinition`.
// Executions resolve their definition via `publishedVersionId` so a mid-edit
// draft never alters in-flight runs. See `.context/orchestration/workflow-versioning.md`.
model AiWorkflow {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  description        String   @db.Text
  draftDefinition    Json? // in-progress edit; null when there is no draft
  publishedVersionId String? // FK to the version executions pin to
  patternsUsed       Int[] // pattern numbers used in this workflow
  isActive           Boolean  @default(true)
  isTemplate         Boolean  @default(false)
  isSystem           Boolean  @default(false)
  templateSource     String? // null = regular workflow, "builtin" = seed template, "custom" = admin-created
  metadata           Json?
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  creator          User                  @relation("AiWorkflowCreator", fields: [createdBy], references: [id])
  publishedVersion AiWorkflowVersion?    @relation("WorkflowPublishedVersion", fields: [publishedVersionId], references: [id])
  versions         AiWorkflowVersion[]   @relation("WorkflowVersions")
  executions       AiWorkflowExecution[]
  schedules        AiWorkflowSchedule[]
  triggers         AiWorkflowTrigger[]

  @@index([createdBy])
  @@index([isActive])
  @@index([isTemplate])
  @@index([isSystem])
  @@index([slug, isActive]) // Webhook trigger lookups: findFirst({ slug, isActive: true })
  @@index([publishedVersionId])
  @@map("ai_workflow")
}

// Immutable snapshot of a workflow definition at publish time.
// Mirrors the AiAgentVersion model. New rows are inserted by `publishDraft` and
// `rollback`; existing rows are never mutated. Per-execution pinning is via
// `AiWorkflowExecution.versionId`.
model AiWorkflowVersion {
  id            String   @id @default(cuid())
  workflowId    String
  version       Int // monotonic per workflow, starts at 1
  snapshot      Json // full WorkflowDefinition at publish time
  changeSummary String?  @db.Text // optional admin-supplied label
  createdBy     String
  createdAt     DateTime @default(now())

  workflow     AiWorkflow            @relation("WorkflowVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  creator      User                  @relation("WorkflowVersionCreator", fields: [createdBy], references: [id])
  publishedFor AiWorkflow[]          @relation("WorkflowPublishedVersion")
  executions   AiWorkflowExecution[]

  @@unique([workflowId, version])
  @@index([workflowId])
  @@map("ai_workflow_version")
}

// Cron-based workflow scheduling
model AiWorkflowSchedule {
  id             String    @id @default(cuid())
  workflowId     String
  name           String
  cronExpression String    @db.VarChar(100)
  inputTemplate  Json      @default("{}")
  isEnabled      Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  workflow AiWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  creator  User       @relation("AiWorkflowScheduleCreator", fields: [createdBy], references: [id])

  @@index([workflowId])
  @@index([isEnabled, nextRunAt])
  @@map("ai_workflow_schedule")
}

// Inbound trigger from a third-party system (Slack, Postmark, generic-HMAC). Each row
// binds (channel, workflow) so the inbound route can dispatch incoming requests to the
// right workflow. Channel-wide secrets (Slack signing secret, Postmark basic-auth) live
// in env vars; per-trigger generic-HMAC secrets are stored as plaintext on `signingSecret`,
// mirroring `AiEventHook.secret` (HMAC needs the original secret on both sides; the at-rest
// security model treats the DB as admin-trusted). `metadata` carries channel-specific config
// (event-type filter, allowed senders, ...).
model AiWorkflowTrigger {
  id            String    @id @default(cuid())
  workflowId    String
  channel       String    @db.VarChar(40) // "slack" | "postmark" | "hmac"
  name          String
  metadata      Json      @default("{}")
  signingSecret String?   @db.Text // per-trigger HMAC shared secret (plaintext, mirrors AiEventHook.secret); null for env-var-keyed channels
  isEnabled     Boolean   @default(true)
  lastFiredAt   DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workflow AiWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  creator  User       @relation("AiWorkflowTriggerCreator", fields: [createdBy], references: [id])

  @@unique([channel, workflowId]) // one trigger per (channel, workflow); v2 may relax for multi-event setups
  @@index([workflowId])
  @@index([channel, isEnabled])
  @@map("ai_workflow_trigger")
}

// Runtime workflow instances
model AiWorkflowExecution {
  id                String    @id @default(cuid())
  workflowId        String
  versionId         String? // pinned AiWorkflowVersion at trigger time; null on legacy rows only
  status            String // "pending", "running", "paused_for_approval", "completed", "failed", "cancelled"
  inputData         Json
  outputData        Json?
  currentStep       String?
  executionTrace    Json // array of step execution logs
  totalTokensUsed   Int       @default(0)
  totalCostUsd      Float     @default(0)
  budgetLimitUsd    Float?
  startedAt         DateTime?
  completedAt       DateTime?
  errorMessage      String?   @db.Text
  // Trigger attribution. Source is `schedule | webhook | chat | inbound:<channel>` (free-form;
  // not enforced as enum so new sources can be added without migration). External ID carries
  // vendor-supplied identifiers (Slack `event_id`, Postmark `MessageID`); used for human/audit
  // attribution only. Dedup is keyed on `dedupKey` so shared-secret channels (Slack, Postmark)
  // can dedup globally across workflows even though the same external ID is allowed to appear
  // for unrelated per-trigger HMAC events.
  triggerSource     String?   @db.VarChar(50)
  triggerExternalId String?
  dedupKey          String?
  userId            String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  workflow AiWorkflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version  AiWorkflowVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  user     User               @relation("AiWorkflowExecutionUser", fields: [userId], references: [id])
  costLogs AiCostLog[]

  // Inbound-trigger dedup keyed on `dedupKey`. Route computes per-channel scope:
  //   - shared-secret channels (slack, postmark): `<channel>:<externalId>` — globally per channel
  //   - per-trigger HMAC: `hmac:<workflowId>:<externalId>` — scoped per trigger
  // Postgres treats NULLs as distinct, so non-inbound rows (NULL dedupKey) never collide.
  @@unique([dedupKey], name: "ai_workflow_execution_dedup_key")
  @@index([workflowId])
  @@index([versionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, startedAt]) // Zombie reaper: RUNNING rows past threshold
  @@index([status, createdAt]) // Stale-pending reaper + execution list filters
  @@index([status, updatedAt]) // Abandoned-approval reaper
  @@index([userId, status, createdAt]) // Execution list with user + status + sort
  @@map("ai_workflow_execution")
}

// Chat sessions
model AiConversation {
  id                   String   @id @default(cuid())
  userId               String
  agentId              String
  title                String?
  contextType          String?
  contextId            String?
  metadata             Json?
  summary              String?  @db.Text
  summaryUpToMessageId String?
  tags                 String[] @default([])
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  user     User        @relation("AiConversationUser", fields: [userId], references: [id])
  agent    AiAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages AiMessage[]
  costLogs AiCostLog[]

  @@index([userId])
  @@index([agentId])
  @@index([contextType, contextId])
  @@index([isActive])
  @@index([updatedAt])
  @@map("ai_conversation")
}

// Individual messages
model AiMessage {
  id             String    @id @default(cuid())
  conversationId String
  role           String // "user", "assistant", "system", "tool"
  content        String    @db.Text
  metadata       Json? // {tokenUsage, modelUsed, latencyMs, costUsd}
  capabilitySlug String?
  toolCallId     String?
  rating         Int? // -1 = thumbs down, 1 = thumbs up, null = unrated
  ratedAt        DateTime?
  createdAt      DateTime  @default(now())

  // Relations
  conversation     AiConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  evaluationLogs   AiEvaluationLog[]
  messageEmbedding AiMessageEmbedding?

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([role])
  @@index([createdAt])
  @@index([rating])
  @@map("ai_message")
}

// Embedding vector for semantic search over conversation messages
model AiMessageEmbedding {
  id        String                      @id @default(cuid())
  messageId String                      @unique
  embedding Unsupported("vector(1024)")

  message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("ai_message_embedding")
}

// Configurable event hooks for orchestration events
// Fires on events like conversation.started, message.created,
// workflow.completed, etc. Webhook-only action type.
model AiEventHook {
  id        String   @id @default(cuid())
  name      String
  eventType String   @db.VarChar(100) // e.g. "conversation.started", "workflow.completed"
  action    Json // { type: 'webhook', url, headers }
  filter    Json? // optional event filtering e.g. { agentSlug: 'support-bot' }
  isEnabled Boolean  @default(true)
  secret    String?  @db.Text // HMAC-SHA256 signing key (hex); nullable = unsigned
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creator    User                  @relation("AiEventHookCreator", fields: [createdBy], references: [id])
  deliveries AiEventHookDelivery[]

  @@index([eventType])
  @@index([isEnabled])
  @@map("ai_event_hook")
}

// Delivery history / retry queue for webhook-type AiEventHook dispatches.
// Internal handlers run in-process and are not tracked here.
model AiEventHookDelivery {
  id               String    @id @default(cuid())
  hookId           String
  eventType        String
  payload          Json
  status           String    @default("pending") // pending, delivered, failed, exhausted
  attempts         Int       @default(0)
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  lastResponseCode Int?
  lastError        String?   @db.Text
  createdAt        DateTime  @default(now())

  hook AiEventHook @relation(fields: [hookId], references: [id], onDelete: Cascade)

  @@index([hookId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("ai_event_hook_delivery")
}

// Per-user-per-agent key-value memory (preferences, prior topics, facts)
model AiUserMemory {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  key       String   @db.VarChar(255)
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User    @relation("AiUserMemoryUser", fields: [userId], references: [id])
  agent AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId, key])
  @@index([userId, agentId])
  @@map("ai_user_memory")
}

// Source documents uploaded to the knowledge base
model AiKnowledgeDocument {
  id           String   @id @default(cuid())
  name         String
  fileName     String
  fileHash     String // SHA-256 for deduplication
  chunkCount   Int      @default(0)
  status       String // "processing", "ready", "failed"
  scope        String   @default("app") // "system" | "app"
  category     String? // user-assigned or extracted from document metadata
  sourceUrl    String? // URL the document was fetched from (null = manual upload)
  errorMessage String?  @db.Text
  metadata     Json? // format-specific metadata, preview data for pending_review docs
  uploadedBy   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  uploader User               @relation("AiKnowledgeDocumentUploader", fields: [uploadedBy], references: [id])
  chunks   AiKnowledgeChunk[]

  @@index([uploadedBy])
  @@index([status])
  @@index([scope])
  @@index([category])
  @@index([fileHash])
  @@map("ai_knowledge_document")
}

// Vector store for knowledge base content
model AiKnowledgeChunk {
  id                String                       @id @default(cuid())
  chunkKey          String                       @unique
  documentId        String
  content           String                       @db.Text
  embedding         Unsupported("vector(1536)")?
  // GENERATED ALWAYS AS (to_tsvector('english', content || keywords)) STORED — managed by migration, populated by Postgres.
  searchVector      Unsupported("tsvector")?
  chunkType         String // "pattern_section", "pattern_overview", "glossary", etc.
  patternNumber     Int?
  patternName       String?
  category          String?
  section           String?
  keywords          String?                      @db.Text
  estimatedTokens   Int?
  embeddingModel    String? // e.g. "voyage-3", "text-embedding-3-small"
  embeddingProvider String? // e.g. "voyage", "openai-compatible", "ollama"
  embeddedAt        DateTime? // when the embedding was generated
  metadata          Json?

  // Relations
  document AiKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([chunkType])
  @@index([patternNumber])
  @@index([category])
  @@map("ai_knowledge_chunk")
}

// Testing sessions for agents
model AiEvaluationSession {
  id                     String    @id @default(cuid())
  userId                 String
  agentId                String? // nullable so SetNull can preserve history when the agent is deleted
  title                  String
  description            String?   @db.Text
  status                 String // "draft", "in_progress", "completed", "archived"
  summary                String?   @db.Text
  improvementSuggestions Json?
  // { avgFaithfulness, avgGroundedness, avgRelevance, scoredLogCount,
  //   judgeProvider, judgeModel, scoredAt, totalScoringCostUsd }
  metricSummary          Json?
  startedAt              DateTime?
  completedAt            DateTime?
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  user               User                  @relation("AiEvaluationSessionUser", fields: [userId], references: [id])
  agent              AiAgent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  logs               AiEvaluationLog[]
  experimentVariants AiExperimentVariant[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@map("ai_evaluation_session")
}

// Per-turn evaluation logs
model AiEvaluationLog {
  id                String   @id @default(cuid())
  sessionId         String
  messageId         String?
  sequenceNumber    Int
  eventType         String // "user_input", "ai_response", "capability_call", "capability_result", "error"
  content           String?  @db.Text
  inputData         Json?
  outputData        Json?
  capabilitySlug    String?
  executionTimeMs   Int?
  tokenUsage        Json?
  metadata          Json?
  // Named-metric scores attached to ai_response logs by the judge LLM at
  // completion / rescore time. Null until scored. Faithfulness can stay
  // null even after scoring when the response had no inline citations.
  faithfulnessScore Float?
  groundednessScore Float?
  relevanceScore    Float?
  // { faithfulness: { reasoning }, groundedness: { reasoning },
  //   relevance: { reasoning } } — display-only.
  judgeReasoning    Json?
  createdAt         DateTime @default(now())

  // Relations
  session AiEvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message AiMessage?          @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([messageId])
  @@index([eventType])
  @@map("ai_evaluation_log")
}

// Granular cost tracking
model AiCostLog {
  id                  String   @id @default(cuid())
  agentId             String?
  conversationId      String?
  workflowExecutionId String?
  model               String
  provider            String
  inputTokens         Int
  outputTokens        Int
  inputCostUsd        Float
  outputCostUsd       Float
  totalCostUsd        Float
  isLocal             Boolean  @default(false)
  operation           String // "chat", "tool_call", "embedding", "evaluation"
  metadata            Json?
  // OTEL trace correlation — set when an active tracer span exists at the
  // logCost call site. Nullable for legacy rows and for code paths where
  // tracing is not registered (default no-op tracer returns empty IDs).
  traceId             String?
  spanId              String?
  createdAt           DateTime @default(now())

  // Relations
  agent             AiAgent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  conversation      AiConversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  workflowExecution AiWorkflowExecution? @relation(fields: [workflowExecutionId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([conversationId])
  @@index([workflowExecutionId])
  @@index([provider])
  @@index([operation])
  @@index([createdAt])
  @@index([agentId, createdAt])
  @@index([traceId])
  @@map("ai_cost_log")
}

// Webhook subscriptions for outbound event notifications
model AiWebhookSubscription {
  id          String   @id @default(cuid())
  url         String // destination URL (validated as safe)
  secret      String // HMAC-SHA256 signing key
  events      String[] // e.g. ["budget_exceeded","workflow_failed"]
  isActive    Boolean  @default(true)
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User                @relation("AiWebhookUser", fields: [createdBy], references: [id])
  deliveries AiWebhookDelivery[]

  @@index([isActive])
  @@index([createdBy])
  @@map("ai_webhook_subscription")
}

// Webhook delivery tracking — records each delivery attempt for audit + retry
model AiWebhookDelivery {
  id               String    @id @default(cuid())
  subscriptionId   String
  eventType        String
  payload          Json
  status           String    @default("pending") // pending, delivered, failed, exhausted
  attempts         Int       @default(0)
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  lastResponseCode Int?
  lastError        String?   @db.Text
  createdAt        DateTime  @default(now())

  subscription AiWebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("ai_webhook_delivery")
}

// Configured LLM providers
model AiProviderConfig {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  providerType String // "anthropic", "openai-compatible"
  baseUrl      String? // API base URL (required for openai-compatible)
  apiKeyEnvVar String? // env var name e.g. "ANTHROPIC_API_KEY"
  isLocal      Boolean  @default(false)
  isActive     Boolean  @default(true)
  metadata     Json?
  timeoutMs    Int? // per-provider request timeout; null = use default (30s cloud, 10s local)
  maxRetries   Int? // per-provider retry count; null = use default (3)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  creator User @relation("AiProviderConfigCreator", fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([providerType])
  @@index([isActive])
  @@map("ai_provider_config")
}

// Provider model matrix — per-model landscape analysis
model AiProviderModel {
  id           String @id @default(cuid())
  slug         String @unique // "openai-gpt-5", "voyage-voyage-3"
  providerSlug String // groups models: "openai", "anthropic", "voyage"
  modelId      String // API model id: "gpt-5", "voyage-3"
  name         String // display name: "GPT-5", "Voyage 3"
  description  String @db.Text

  // Classification
  capabilities String[] @default(["chat"]) // ["chat"], ["embedding"], ["chat","embedding"]
  tierRole     String // 'thinking' | 'worker' | 'infrastructure' | 'control_plane' | 'local_sovereign' | 'embedding'

  // Selection matrix dimensions
  reasoningDepth String // 'very_high' | 'high' | 'medium' | 'none'
  latency        String // 'very_fast' | 'fast' | 'medium'
  costEfficiency String // 'very_high' | 'high' | 'medium' | 'none'
  contextLength  String // 'very_high' | 'high' | 'medium' | 'n_a'
  toolUse        String // 'strong' | 'moderate' | 'none'
  bestRole       String // free-text, e.g. "Planner / orchestrator"

  // Embedding-specific (nullable for chat-only models)
  dimensions           Int?
  schemaCompatible     Boolean?
  costPerMillionTokens Float?
  hasFreeTier          Boolean?
  local                Boolean  @default(false)
  quality              String? // 'high' | 'medium' | 'budget'
  strengths            String?  @db.Text
  setup                String?  @db.Text

  // Lifecycle
  isDefault Boolean  @default(false) // true = seed-managed, re-seedable
  isActive  Boolean  @default(true)
  metadata  Json?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creator User @relation("AiProviderModelCreator", fields: [createdBy], references: [id])

  @@unique([providerSlug, modelId])
  @@index([createdBy])
  @@index([isActive])
  @@index([tierRole])
  @@index([providerSlug])
  @@map("ai_provider_model")
}

// Per-user API key for programmatic access (alternative to session auth)
model AiApiKey {
  id           String    @id @default(cuid())
  userId       String
  name         String // admin-friendly label (e.g. "My CI Key")
  keyHash      String    @unique // SHA-256 hash of the API key (key itself never stored)
  keyPrefix    String // first 8 chars for display (e.g. "sk_abc12...")
  scopes       String[]  @default(["chat"]) // "chat", "analytics", "knowledge", "admin"
  rateLimitRpm Int? // per-key rate limit (requests per minute); null = use global default
  lastUsedAt   DateTime?
  expiresAt    DateTime? // null = never expires
  revokedAt    DateTime? // non-null = revoked
  createdAt    DateTime  @default(now())

  user User @relation("AiApiKeyUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("ai_api_key")
}

/// Singleton settings row for agent orchestration, keyed by `slug = "global"`.
///
/// Holds admin-editable defaults that cross-cut the orchestration layer:
///   * `defaultModels` — `{ routing, chat, reasoning, embeddings }` map used by
///     `getDefaultModelForTask()` in `lib/orchestration/llm/model-registry.ts`.
///   * `globalMonthlyBudgetUsd` — optional month-to-date spend ceiling across
///     *all* agents, consulted by `checkBudget()` in `lib/orchestration/llm/cost-tracker.ts`.
///
/// Upserted lazily on the first `GET /api/v1/admin/orchestration/settings`
/// call; never touched by the seeder so admin edits survive deploys.
model AiOrchestrationSettings {
  id                         String    @id @default(cuid())
  slug                       String    @unique @default("global")
  defaultModels              Json // { routing: string, chat: string, reasoning: string, embeddings: string }
  globalMonthlyBudgetUsd     Float?
  searchConfig               Json? // { keywordBoostWeight: number, vectorWeight: number }
  lastSeededAt               DateTime?
  defaultApprovalTimeoutMs   Int? // ms before auto-action on approval gates; null = no timeout
  approvalDefaultAction      String?   @default("deny") // "deny" or "allow"
  inputGuardMode             String?   @default("log_only") // "log_only", "warn_and_continue", "block"
  outputGuardMode            String?   @default("log_only") // "log_only", "warn_and_continue", "block"
  citationGuardMode          String?   @default("log_only") // "log_only", "warn_and_continue", "block"
  webhookRetentionDays       Int?
  costLogRetentionDays       Int?
  auditLogRetentionDays      Int?
  maxConversationsPerUser    Int?
  maxMessagesPerConversation Int?
  escalationConfig           Json? // { emailAddresses, webhookUrl?, notifyOnPriority }
  embedAllowedOrigins        Json      @default("[]") // [string] — allowlist for the /approvals/:id/{approve,reject}/embed CORS scope
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@map("ai_orchestration_settings")
}

/// Immutable audit trail for admin configuration changes.
///
/// Fire-and-forget writes — never blocks the request. Tracks agent edits,
/// workflow changes, knowledge uploads, settings changes, and deletions.
model AiAdminAuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String // e.g. "agent.create", "agent.update", "workflow.delete"
  entityType String // "agent", "workflow", "capability", "knowledge_document", "settings", "webhook"
  entityId   String?
  entityName String? // human-readable name at time of action
  changes    Json? // { field: { from, to } } diff for updates
  metadata   Json? // extra context
  clientIp   String?
  createdAt  DateTime @default(now())

  user User @relation("AiAdminAuditLogUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("ai_admin_audit_log")
}

// A/B prompt experiment — compares agent version variants
model AiExperiment {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  status      String   @default("draft") // "draft" | "running" | "completed"
  agentId     String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent    AiAgent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator  User                  @relation("AiExperimentCreator", fields: [createdBy], references: [id])
  variants AiExperimentVariant[]

  @@index([agentId])
  @@index([status])
  @@map("ai_experiment")
}

// A variant (arm) in an A/B experiment — points to an agent version snapshot
model AiExperimentVariant {
  id                  String  @id @default(cuid())
  experimentId        String
  agentVersionId      String? // references AiAgentVersion.id (null if using live agent)
  evaluationSessionId String? // filled when experiment is run
  label               String // e.g. "Control", "Variant A"
  score               Float? // aggregated evaluation score after run

  experiment        AiExperiment         @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  evaluationSession AiEvaluationSession? @relation(fields: [evaluationSessionId], references: [id], onDelete: SetNull)

  @@index([experimentId])
  @@index([evaluationSessionId])
  @@map("ai_experiment_variant")
}

/// Tracks which seed units have been applied, keyed by unit name.
///
/// Each entry in `prisma/seeds/` is hashed by source content; the runner
/// skips units whose hash matches the stored `contentHash`, and re-runs
/// units whose file has changed. This lets teammates pull new/edited
/// seeds and apply them incrementally without manual coordination.
model SeedHistory {
  id          String   @id @default(cuid())
  name        String   @unique
  contentHash String
  appliedAt   DateTime @default(now())
  durationMs  Int

  @@map("seed_history")
}

// ============================================================================
// MCP Server
// ============================================================================

/// Singleton settings row for MCP server configuration, keyed by `slug = "global"`.
///
/// Controls the master enable/disable switch and global defaults for MCP
/// server behaviour. Upserted lazily on first read, matching the
/// `AiOrchestrationSettings` pattern.
model McpServerConfig {
  id                 String   @id @default(cuid())
  slug               String   @unique @default("global")
  isEnabled          Boolean  @default(false)
  serverName         String   @default("Sunrise MCP Server")
  serverVersion      String   @default("1.0.0")
  maxSessionsPerKey  Int      @default(5)
  globalRateLimit    Int      @default(60) // requests per minute per API key
  auditRetentionDays Int      @default(90)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("mcp_server_config")
}

/// Pivot table linking an AiCapability to MCP exposure.
///
/// Each capability can be optionally exposed as an MCP tool. `isEnabled`
/// defaults to false (default-deny) — nothing is exposed until an admin
/// explicitly enables it.
model McpExposedTool {
  id                String  @id @default(cuid())
  capabilityId      String  @unique
  isEnabled         Boolean @default(false)
  customName        String? // override MCP tool name (must match ^[a-z][a-z0-9_]*$)
  customDescription String? @db.Text
  rateLimitPerKey   Int? // per-key calls/min; null = use capability default
  requiresScope     String? // optional scope string for fine-grained access

  // Relations
  capability AiCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@index([isEnabled])
  @@map("mcp_exposed_tool")
}

/// Data endpoints exposed via MCP resources.
///
/// Each resource has a `sunrise://` URI and maps to an internal handler
/// that returns data without any external fetch.
model McpExposedResource {
  id            String  @id @default(cuid())
  uri           String  @unique // e.g. "sunrise://knowledge/search"
  name          String
  description   String  @db.Text
  mimeType      String  @default("application/json")
  resourceType  String // "knowledge_search", "agent_list", "pattern_detail", "workflow_list"
  isEnabled     Boolean @default(false)
  handlerConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
  @@index([resourceType])
  @@map("mcp_exposed_resource")
}

/// Bearer tokens for MCP client authentication.
///
/// Only the SHA-256 hash of the key is stored — the plaintext is returned
/// once at creation and never again. Keys use a `smcp_` prefix for easy
/// identification.
model McpApiKey {
  id                String    @id @default(cuid())
  name              String
  keyHash           String    @unique // SHA-256 hash of the API key
  keyPrefix         String // first 8 chars for UI identification (e.g. "smcp_a1b2")
  scopes            String[] // e.g. ["tools:list", "tools:execute", "resources:read"]
  isActive          Boolean   @default(true)
  expiresAt         DateTime?
  lastUsedAt        DateTime?
  rateLimitOverride Int? // per-key rate limit override; null = use global default
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  creator   User          @relation("McpApiKeyCreator", fields: [createdBy], references: [id])
  auditLogs McpAuditLog[]

  @@index([keyHash])
  @@index([createdBy])
  @@index([isActive])
  @@map("mcp_api_key")
}

/// Immutable audit trail for MCP server operations.
///
/// Every MCP method call is logged with client IP, duration, and result.
/// Request params are sanitized and truncated before storage.
model McpAuditLog {
  id            String   @id @default(cuid())
  apiKeyId      String?
  method        String // "tools/call", "tools/list", "resources/read", "initialize", etc.
  toolSlug      String?
  resourceUri   String?
  requestParams Json? // sanitized, truncated to 10KB
  responseCode  String // "success", "error", "rate_limited"
  errorMessage  String?  @db.Text
  durationMs    Int
  clientIp      String?
  userAgent     String?
  createdAt     DateTime @default(now())

  // Relations
  apiKey McpApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([apiKeyId])
  @@index([createdAt])
  @@index([method])
  @@index([toolSlug])
  @@map("mcp_audit_log")
}
